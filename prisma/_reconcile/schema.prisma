generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AIInvocation {
  id               String   @id
  endpoint         String
  inputHash        String
  model            String?
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  costEstimate     Float    @default(0)
  durationMs       Int      @default(0)
  staffId          String?
  createdAt        DateTime @default(now())

  @@index([createdAt(sort: Desc)], map: "AIInvocation_createdAt_desc_idx")
  @@index([endpoint])
  @@index([staffId])
}

model AccountCategoryMargin {
  id           String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  builderId    String
  category     String
  categoryType CategoryType @default(CORE)
  targetMargin Float        @default(0.25)
  minMargin    Float        @default(0.15)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @default(now())
  Builder      Builder      @relation(fields: [builderId], references: [id], onDelete: Cascade)

  @@unique([builderId, category], map: "AccountCategoryMargin_builder_cat_key")
  @@index([builderId])
}

model AccountMarginTarget {
  id                  String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  builderId           String   @unique
  targetBlendedMargin Float    @default(0.30)
  notes               String?
  setById             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now())
  Builder             Builder  @relation(fields: [builderId], references: [id], onDelete: Cascade)
}

model AccountReviewTrigger {
  id          String    @id
  builderId   String
  triggerType String
  severity    String?   @default("MEDIUM")
  description String?
  isResolved  Boolean?  @default(false)
  resolvedBy  String?
  resolvedAt  DateTime? @db.Timestamptz(6)
  createdAt   DateTime? @default(now()) @db.Timestamptz(6)

  @@index([builderId], map: "idx_review_trigger_builder")
  @@index([isResolved], map: "idx_review_trigger_resolved")
}

model AccountTouchpoint {
  id           String    @id
  builderId    String
  staffId      String?
  touchType    String
  channel      String?   @default("PHONE")
  subject      String?
  notes        String?
  outcome      String?
  followUpDate DateTime? @db.Date
  createdAt    DateTime? @default(now()) @db.Timestamptz(6)

  @@index([builderId], map: "idx_touchpoint_builder")
  @@index([createdAt], map: "idx_touchpoint_date")
}

model Activity {
  id           String       @id
  staffId      String
  builderId    String?
  jobId        String?
  activityType ActivityType
  subject      String
  notes        String?
  outcome      String?
  scheduledAt  DateTime?
  completedAt  DateTime?
  durationMins Int?
  createdAt    DateTime     @default(now())
  communityId  String?
  Job          Job?         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  Staff        Staff        @relation(fields: [staffId], references: [id])

  @@index([activityType])
  @@index([builderId])
  @@index([communityId])
  @@index([createdAt])
  @@index([jobId])
  @@index([staffId])
  @@index([builderId, createdAt(sort: Desc)], map: "idx_activity_builder_created")
  @@index([jobId, createdAt(sort: Desc)], map: "idx_activity_job_created")
}

model AgentConfig {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  agentRole   String
  configKey   String
  configValue Json
  description String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@unique([agentRole, configKey], map: "AgentConfig_role_key_unique")
  @@index([agentRole], map: "idx_agentconfig_role")
}

model AgentConversation {
  id                    String                  @id @default(dbgenerated("(gen_random_uuid())::text"))
  builderId             String
  channel               String                  @default("PORTAL")
  status                String                  @default("ACTIVE")
  subject               String?
  lastMessageAt         DateTime?               @default(now()) @db.Timestamptz(6)
  escalatedTo           String?
  escalatedAt           DateTime?               @db.Timestamptz(6)
  resolvedAt            DateTime?               @db.Timestamptz(6)
  metadata              Json?                   @default("{}")
  createdAt             DateTime?               @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime?               @default(now()) @db.Timestamptz(6)
  Builder               Builder                 @relation(fields: [builderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Staff                 Staff?                  @relation(fields: [escalatedTo], references: [id], onDelete: NoAction, onUpdate: NoAction)
  AgentEmailLog         AgentEmailLog[]
  AgentSmsLog           AgentSmsLog[]
  ScheduleChangeRequest ScheduleChangeRequest[]

  @@index([builderId], map: "idx_agent_conv_builder")
  @@index([channel], map: "idx_agent_conv_channel")
  @@index([status], map: "idx_agent_conv_status")
}

model AgentEmailLog {
  id                String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  conversationId    String?
  builderId         String?
  fromEmail         String
  toEmail           String
  subject           String?
  body              String
  direction         String             @default("INBOUND")
  externalId        String?
  status            String?            @default("RECEIVED")
  createdAt         DateTime?          @default(now()) @db.Timestamptz(6)
  Builder           Builder?           @relation(fields: [builderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  AgentConversation AgentConversation? @relation(fields: [conversationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([conversationId], map: "idx_email_log_conv")
}

model AgentMessage {
  id            String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  fromAgent     String
  toAgent       String
  messageType   String     @default("INFO")
  subject       String
  body          Json?
  priority      String     @default("NORMAL")
  relatedTaskId String?
  readAt        DateTime?
  respondedAt   DateTime?
  createdAt     DateTime   @default(now())
  AgentTask     AgentTask? @relation(fields: [relatedTaskId], references: [id])

  @@index([fromAgent, createdAt], map: "idx_agentmsg_from")
  @@index([toAgent, readAt], map: "idx_agentmsg_to")
  @@index([messageType], map: "idx_agentmsg_type")
}

model AgentSession {
  id                  String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  agentRole           String     @unique
  status              String     @default("OFFLINE")
  currentTaskId       String?
  lastHeartbeat       DateTime?
  tasksCompletedToday Int        @default(0)
  tasksFailedToday    Int        @default(0)
  errorsToday         Int        @default(0)
  startedAt           DateTime?
  metadata            Json?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @default(now())
  AgentTask           AgentTask? @relation(fields: [currentTaskId], references: [id])
}

model AgentSmsLog {
  id                String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  conversationId    String?
  builderId         String?
  phoneNumber       String
  direction         String             @default("INBOUND")
  body              String
  externalId        String?
  status            String?            @default("SENT")
  createdAt         DateTime?          @default(now()) @db.Timestamptz(6)
  Builder           Builder?           @relation(fields: [builderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  AgentConversation AgentConversation? @relation(fields: [conversationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([conversationId], map: "idx_sms_log_conv")
}

model AgentTask {
  id               String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  agentRole        String
  taskType         String
  priority         String         @default("NORMAL")
  status           String         @default("PENDING")
  title            String
  description      String?
  payload          Json?
  result           Json?
  createdBy        String
  assignedTo       String?
  parentTaskId     String?
  requiresApproval Boolean        @default(false)
  approvedBy       String?
  approvedAt       DateTime?
  claimedAt        DateTime?
  completedAt      DateTime?
  failedAt         DateTime?
  failReason       String?
  dueBy            DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now())
  AgentMessage     AgentMessage[]
  AgentSession     AgentSession[]

  @@index([assignedTo, status], map: "idx_agenttask_assignedto")
  @@index([parentTaskId], map: "idx_agenttask_parent")
  @@index([priority, createdAt], map: "idx_agenttask_priority")
  @@index([agentRole, status], map: "idx_agenttask_role_status")
  @@index([taskType, status], map: "idx_agenttask_type")
}

model AlertIncident {
  id              String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  alertId         String
  title           String
  href            String?
  description     String?
  startedAt       DateTime  @default(now()) @db.Timestamptz(6)
  endedAt         DateTime? @db.Timestamptz(6)
  peakCount       Int       @default(0)
  peakSeverity    String
  lastSeverity    String
  lastCount       Int       @default(0)
  lastSeenAt      DateTime  @default(now()) @db.Timestamptz(6)
  tickCount       Int       @default(1)
  notifiedAt      DateTime? @db.Timestamptz(6)
  escalationCount Int       @default(0)

  @@index([alertId, startedAt(sort: Desc)], map: "idx_alertincident_alertid")
  @@index([startedAt(sort: Desc)], map: "idx_alertincident_started")
}

model AlertMute {
  alertId    String   @id
  mutedUntil DateTime @db.Timestamptz(6)
  reason     String?
  mutedBy    String?
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  @@index([mutedUntil(sort: Desc)], map: "idx_alertmute_until")
}

model AuditLog {
  id        String   @id
  staffId   String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  severity  String?  @default("INFO")

  @@index([createdAt(sort: Desc)])
  @@index([staffId])
  @@index([action], map: "idx_auditlog_action")
  @@index([createdAt(sort: Desc)], map: "idx_auditlog_created")
  @@index([entity, entityId], map: "idx_auditlog_entity")
  @@index([severity], map: "idx_auditlog_severity")
  @@index([staffId, createdAt(sort: Desc)], map: "idx_auditlog_staff")
}

model AutoPurchaseOrder {
  id             String    @id
  vendorName     String    @default("Unknown")
  vendorId       String?
  status         String    @default("RECOMMENDED")
  items          Json      @default("[]")
  estimatedTotal Float     @default(0)
  reason         String?
  approvedBy     String?
  approvedAt     DateTime?
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())

  @@index([status])
  @@index([status], map: "idx_autopo_status")
}

model AutomationLog {
  id             String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  ruleId         String?
  ruleName       String?
  trigger        String?
  status         String?         @default("SUCCESS")
  actionsRun     Int?            @default(0)
  details        Json?           @default("{}")
  error          String?
  executedAt     DateTime?       @default(now()) @db.Timestamptz(6)
  AutomationRule AutomationRule? @relation(fields: [ruleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([ruleId], map: "idx_automation_log_rule")
}

model AutomationRule {
  id            String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  name          String
  description   String?
  trigger       String
  conditions    Json?           @default("{}")
  actions       Json?           @default("[]")
  roles         String[]        @default([])
  frequency     String?         @default("ON_TRIGGER")
  enabled       Boolean?        @default(true)
  lastRunAt     DateTime?       @db.Timestamptz(6)
  runCount      Int?            @default(0)
  createdById   String?
  createdAt     DateTime?       @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime?       @default(now()) @db.Timestamptz(6)
  AutomationLog AutomationLog[]

  @@index([trigger], map: "idx_automation_rule_trigger")
}

model BTProjectMapping {
  id             String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  btProjectId    String    @unique(map: "BTProjectMapping_btProjectId_unique")
  btProjectName  String?
  btBuilderName  String?
  btCommunity    String?
  btLot          String?
  btStatus       String?
  btScheduleData Json?     @default("{}")
  builderId      String?
  projectId      String?
  jobId          String?
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())
  Builder        Builder?  @relation(fields: [builderId], references: [id])
  Job            Job?      @relation(fields: [jobId], references: [id])

  @@index([builderId])
}

model BackorderItem {
  id                    String    @id
  orderId               String
  orderItemId           String?
  deliveryId            String?
  productId             String
  sku                   String
  productName           String
  qtyOrdered            Int
  qtyShipped            Int       @default(0)
  qtyBackordered        Int       @default(0)
  status                String    @default("BACKORDERED")
  followUpDeliveryId    String?
  scheduledDeliveryDate DateTime?
  materialArrivedAt     DateTime?
  purchaseOrderId       String?
  builderNotified       Boolean   @default(false)
  builderNotifiedAt     DateTime?
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now())

  @@index([deliveryId])
  @@index([followUpDeliveryId])
  @@index([orderId])
  @@index([productId])
  @@index([purchaseOrderId])
  @@index([status])
}

model BayMovement {
  id                                               String        @id
  doorId                                           String
  fromBayId                                        String?
  toBayId                                          String
  movedBy                                          String?
  movedByName                                      String?
  reason                                           String?
  createdAt                                        DateTime?     @default(now()) @db.Timestamp(6)
  DoorIdentity                                     DoorIdentity  @relation(fields: [doorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  WarehouseBay_BayMovement_fromBayIdToWarehouseBay WarehouseBay? @relation("BayMovement_fromBayIdToWarehouseBay", fields: [fromBayId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  WarehouseBay_BayMovement_toBayIdToWarehouseBay   WarehouseBay  @relation("BayMovement_toBayIdToWarehouseBay", fields: [toBayId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([doorId], map: "idx_bay_movement_doorId")
  @@index([toBayId], map: "idx_bay_movement_toBayId")
}

model Blueprint {
  id               String           @id
  projectId        String
  fileName         String
  fileUrl          String
  fileSize         Int
  fileType         String
  pageCount        Int?
  processedAt      DateTime?
  processingStatus ProcessingStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  Project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Takeoff          Takeoff[]

  @@index([processingStatus])
  @@index([projectId])
}

model BoltCommunity {
  id         String    @id
  boltId     String    @unique
  name       String
  city       String?
  state      String?
  customer   String?
  supervisor String?
  active     Boolean?  @default(true)
  createdAt  DateTime? @default(now()) @db.Timestamptz(6)
}

model BoltCrew {
  id        String    @id
  boltId    String    @unique
  name      String
  truck     String?
  active    Boolean?  @default(true)
  phone     String?
  crewType  String?   @default("Other")
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
}

model BoltCustomer {
  id        String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  boltId    String?   @unique
  name      String?
  status    String?
  rawCells  Json?
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @db.Timestamptz(6)
}

model BoltEmployee {
  id        String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  boltId    String?   @unique
  name      String?
  email     String?
  role      String?
  rawCells  Json?
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @db.Timestamptz(6)
}

model BoltFloorplan {
  id         String    @id
  boltId     String    @unique
  name       String
  sqft       Int?
  community  String?
  customer   String?
  city       String?
  state      String?
  activeDate DateTime? @db.Timestamptz(6)
  createdAt  DateTime? @default(now()) @db.Timestamptz(6)
}

model BoltJob {
  id        String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  boltId    String?   @unique
  address   String?
  zip       String?
  floorplan String?
  community String?
  city      String?
  jobType   String?
  startDate DateTime? @db.Timestamptz(6)
  closeDate DateTime? @db.Timestamptz(6)
  startRaw  String?
  closeRaw  String?
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @db.Timestamptz(6)

  @@index([address], map: "idx_boltjob_addr")
  @@index([community], map: "idx_boltjob_comm")
}

model BoltWOType {
  id        String    @id
  name      String    @unique
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
}

model BoltWorkOrder {
  id            String    @id
  boltId        String    @unique
  jobAddress    String?
  woType        String?
  scheduledDate DateTime? @db.Timestamptz(6)
  stage         String?
  assignedTo    String?
  orderedBy     String?
  createdAt     DateTime? @default(now()) @db.Timestamptz(6)
  jobId         String?

  @@index([jobAddress], map: "idx_boltwo_addr")
  @@index([stage], map: "idx_boltwo_stage")
}

model BomEntry {
  id                                    String   @id
  parentId                              String
  componentId                           String
  quantity                              Float    @default(1)
  componentType                         String?
  createdAt                             DateTime @default(now())
  updatedAt                             DateTime @default(now())
  Product_BomEntry_componentIdToProduct Product  @relation("BomEntry_componentIdToProduct", fields: [componentId], references: [id], onDelete: Cascade)
  Product_BomEntry_parentIdToProduct    Product  @relation("BomEntry_parentIdToProduct", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([parentId, componentId])
  @@index([parentId])
}

model BpwCheck {
  id          String    @id
  bpwCheckId  String    @unique
  checkNumber String?
  checkDate   DateTime? @db.Timestamptz(6)
  total       Float?    @default(0)
  ach         String?   @default("No")
  vendor      String?
  createdAt   DateTime? @default(now()) @db.Timestamptz(6)

  @@index([checkDate], map: "idx_bpw_check_date")
}

model BpwCommunity {
  id        String    @id
  bpwId     String    @unique
  name      String
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
}

model BpwFieldPO {
  id            String    @id
  poNumber      String    @unique
  effectiveDate DateTime? @db.Timestamptz(6)
  type          String?
  issuer        String?
  community     String?
  lot           String?
  description   String?
  amount        Float?    @default(0)
  status        String?
  invoiceInfo   String?
  createdAt     DateTime? @default(now()) @db.Timestamptz(6)

  @@index([community], map: "idx_bpw_fpo_community")
}

model BpwInvoice {
  id            String    @id
  bpwInvoiceId  String    @unique
  invoiceNumber String?
  invoiceDate   DateTime? @db.Timestamptz(6)
  description   String?
  amount        Float?    @default(0)
  checkNumber   String?
  bpwCheckId    String?
  checkDate     DateTime? @db.Timestamptz(6)
  createdAt     DateTime? @default(now()) @db.Timestamptz(6)

  @@index([checkNumber], map: "idx_bpw_invoice_checkNumber")
  @@index([invoiceDate], map: "idx_bpw_invoice_date")
}

model BpwJobDetail {
  id                String    @id
  jobId             String
  bpwPulteId        String    @unique
  plan              String?
  elevation         String?
  npc               String?
  fieldManager      String?
  fieldManagerPhone String?
  permit            String?
  scarStart         DateTime? @db.Timestamptz(6)
  scarEnd           DateTime? @db.Timestamptz(6)
  updatedAt         DateTime? @default(now()) @db.Timestamptz(6)

  @@index([jobId], map: "idx_bpw_job_detail_jobId")
}

model Builder {
  id                                                         String                  @id
  companyName                                                String
  contactName                                                String
  email                                                      String                  @unique
  passwordHash                                               String
  phone                                                      String?
  address                                                    String?
  city                                                       String?
  state                                                      String?
  zip                                                        String?
  licenseNumber                                              String?
  paymentTerm                                                PaymentTerm             @default(NET_15)
  creditLimit                                                Float?
  accountBalance                                             Float                   @default(0)
  taxExempt                                                  Boolean                 @default(false)
  taxId                                                      String?
  status                                                     AccountStatus           @default(PENDING)
  emailVerified                                              Boolean                 @default(false)
  verifyToken                                                String?
  createdAt                                                  DateTime                @default(now())
  updatedAt                                                  DateTime
  organizationId                                             String?
  role                                                       BuilderRole             @default(PRIMARY)
  source                                                     LeadSource?
  sourceDetail                                               String?
  resetToken                                                 String?
  resetTokenExpiry                                           DateTime?               @db.Timestamp(6)
  approvalStatus                                             String?                 @default("ACTIVE")
  qbListId                                                   String?
  qbSyncedAt                                                 DateTime?
  segmentTag                                                 String?                 @default("STANDARD")
  lifetimeValue                                              Float?                  @default(0)
  churnRisk                                                  String?                 @default("LOW")
  lastAnalyzedAt                                             DateTime?
  divisionId                                                 String?
  pricingTier                                                String?                 @default("STANDARD")
  notifyEmail                                                Boolean?                @default(true)
  notifySms                                                  Boolean?                @default(false)
  notifyDeliveryUpdates                                      Boolean?                @default(true)
  notifyInvoiceReady                                         Boolean?                @default(true)
  notifyPaymentReceived                                      Boolean?                @default(true)
  builderType                                                BuilderType?            @default(CUSTOM)
  territory                                                  String?
  annualVolume                                               Int?
  website                                                    String?
  AccountCategoryMargin                                      AccountCategoryMargin[]
  AccountMarginTarget                                        AccountMarginTarget?
  AgentConversation                                          AgentConversation[]
  AgentEmailLog                                              AgentEmailLog[]
  AgentSmsLog                                                AgentSmsLog[]
  BTProjectMapping                                           BTProjectMapping[]
  Division                                                   Division?               @relation(fields: [divisionId], references: [id])
  BuilderOrganization                                        BuilderOrganization?    @relation(fields: [organizationId], references: [id])
  BuilderBranding                                            BuilderBranding?
  BuilderCatalog                                             BuilderCatalog[]
  BuilderContact                                             BuilderContact[]
  BuilderIntelligence                                        BuilderIntelligence?
  BuilderPhaseConfig                                         BuilderPhaseConfig[]
  BuilderPricing                                             BuilderPricing[]
  BuilderReferral_BuilderReferral_referredBuilderIdToBuilder BuilderReferral[]       @relation("BuilderReferral_referredBuilderIdToBuilder")
  BuilderReferral_BuilderReferral_referrerIdToBuilder        BuilderReferral[]       @relation("BuilderReferral_referrerIdToBuilder")
  BuilderScheduleShare                                       BuilderScheduleShare[]
  CommunicationLog                                           CommunicationLog[]
  Community                                                  Community[]
  HomeownerAccess                                            HomeownerAccess[]
  LienRelease                                                LienRelease[]
  MessageReadReceipt                                         MessageReadReceipt[]
  Order                                                      Order[]
  OrderTemplate                                              OrderTemplate[]
  Project                                                    Project[]
  ReorderSuggestion                                          ReorderSuggestion[]
  SavedCart                                                  SavedCart[]
  ScheduleChangeRequest                                      ScheduleChangeRequest[]
  SubcontractorPricing                                       SubcontractorPricing[]
  TradeReview                                                TradeReview[]

  @@index([builderType])
  @@index([createdAt])
  @@index([divisionId])
  @@index([email])
  @@index([organizationId])
  @@index([resetToken])
  @@index([status])
  @@index([pricingTier], map: "idx_builder_pricing_tier")
  @@index([status, companyName], map: "idx_builder_status_company")
}

model BuilderApplication {
  id                    String    @id
  builderId             String?
  companyName           String
  contactName           String
  contactEmail          String
  contactPhone          String?
  address               String?
  city                  String?
  state                 String?
  zip                   String?
  businessLicense       String?
  taxId                 String?
  estimatedAnnualVolume String?
  referralSource        String?
  notes                 String?
  status                String    @default("PENDING_APPROVAL")
