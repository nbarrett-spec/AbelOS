// ─── Webhook Infrastructure (previously raw SQL — schema drift fix) ───────

model WebhookEvent {
  id            String    @id @default(cuid())
  provider      String
  eventId       String
  eventType     String?
  status        String    @default("RECEIVED") // RECEIVED | PROCESSING | PROCESSED | FAILED | DEAD_LETTER
  error         String?
  payload       Json?
  retryCount    Int       @default(0)
  maxRetries    Int       @default(5)
  nextRetryAt   DateTime?
  lastAttemptAt DateTime?
  receivedAt    DateTime  @default(now())
  processedAt   DateTime?

  @@unique([provider, eventId])
  @@index([receivedAt(sort: Desc)])
  @@index([provider, status])
  @@index([status, nextRetryAt])
}

// ─── Cron Observability ──────────────────────────────────────────────────

model CronRun {
  id          String    @id @default(cuid())
  name        String
  status      String    @default("RUNNING") // RUNNING | SUCCESS | FAILED
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  result      Json? // Summary payload (rows processed, errors, etc.)
  error       String?
  triggeredBy String    @default("SCHEDULE") // SCHEDULE | MANUAL

  @@index([name, startedAt(sort: Desc)])
  @@index([status])
}

// ─── DATA QUALITY WATCHDOG ──────────────────────────────────────────────────

model DataQualityRule {
  id          String  @id @default(cuid())
  name        String
  description String?
  entity      String // Job, Product, Builder, Invoice, PurchaseOrder, etc.
  severity    String  @default("WARNING") // CRITICAL | WARNING | INFO
  query       String // SQL query that returns violating rows
  fixUrl      String? // URL pattern to fix the issue (e.g. /ops/jobs/{id})
  isActive    Boolean @default(true)

  issues DataQualityIssue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entity])
  @@index([isActive])
}

model DataQualityIssue {
  id          String          @id @default(cuid())
  ruleId      String
  rule        DataQualityRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  entityType  String
  entityId    String
  entityLabel String? // Human-readable label (job number, product name, etc.)
  status      String          @default("OPEN") // OPEN | ACKNOWLEDGED | FIXED | IGNORED
  fixedAt     DateTime?
  fixedBy     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ruleId, entityId])
  @@index([status])
  @@index([entityType, entityId])
  @@index([ruleId, status])
}

// ─── Unified Inbox ──────────────────────────────────────────────────────

model InboxItem {
  id          String  @id @default(cuid())
  type        String // MRP_RECOMMENDATION | COLLECTION_ACTION | DEAL_FOLLOWUP | AGENT_TASK | PO_APPROVAL | QC_ALERT | MATERIAL_ARRIVAL | OUTREACH_REVIEW | SCHEDULE_CHANGE | SYSTEM
  source      String // Which system generated it (mrp, collections, sales, agent-hub, etc.)
  title       String
  description String?
  priority    String  @default("MEDIUM") // CRITICAL | HIGH | MEDIUM | LOW
  status      String  @default("PENDING") // PENDING | APPROVED | REJECTED | SNOOZED | EXPIRED | COMPLETED

  // Link to source entity
  entityType String? // PurchaseOrder, CollectionAction, Deal, Task, etc.
  entityId   String?

  // Financial impact (for prioritization)
  financialImpact Float? // Dollar impact of this action

  // Assignment
  assignedTo String? // Staff ID

  // Action metadata
  actionData Json? // Payload needed to execute the action
  result     Json? // What happened after approve/reject

  // Timing
  dueBy        DateTime? // SLA deadline
  snoozedUntil DateTime?
  resolvedAt   DateTime?
  resolvedBy   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NUC brain write-back ack: timestamp set when the NUC engine POSTs to
  // /api/v1/engine/inbox/[id]/ack confirming it retrieved the resolution
  // payload. Lets the engine know the loop closed on both sides.
  brainAcknowledgedAt DateTime?

  // NUC brain learnings: free-form JSON the engine stamps back on ack.
  // Shape is owned by the NUC (e.g. { confidence, appliedRules[], modelVersion,
  // reasoningSummary, nextWatchSignals[] }). Aegis stores as-is and exposes it
  // via the patterns endpoint so future analyses can aggregate across items.
  brainLearnings Json?

  @@index([status, priority])
  @@index([assignedTo, status])
  @@index([type, status])
  @@index([dueBy])
  @@index([entityType, entityId])
  @@index([createdAt(sort: Desc)])
  @@index([brainAcknowledgedAt])
}

// ─── AI INVOCATION LEDGER ────────────────────────────────────────────
// Every Anthropic API call (via src/lib/ai/insights.ts) is recorded here so
// we can rollup spend per endpoint, per staff, per day. The table is also
// auto-created at runtime inside the helper so local/dev works without a
// migration. A migration will be generated at the next `prisma migrate dev`.
model AIInvocation {
  id               String   @id @default(cuid())
  endpoint         String
  inputHash        String
  model            String?
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  costEstimate     Float    @default(0)
  durationMs       Int      @default(0)
  staffId          String?
  createdAt        DateTime @default(now())

  @@index([endpoint])
  @@index([staffId])
  @@index([createdAt(sort: Desc)])
}

// ── Stock Transfers ─────────────────────────────────────────────
model StockTransfer {
  id             String              @id @default(cuid())
  transferNumber String              @unique
  fromLocation   String
  toLocation     String
  status         String              @default("PENDING") // PENDING | IN_TRANSIT | COMPLETED | CANCELLED
  notes          String?
  createdById    String
  completedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  items          StockTransferItem[]

  @@index([status])
  @@index([createdById])
}

model StockTransferItem {
  id          String        @id @default(cuid())
  transferId  String
  transfer    StockTransfer @relation(fields: [transferId], references: [id])
  productId   String
  sku         String?
  productName String?
  quantity    Int
  damagedQty  Int           @default(0)
  notes       String?
  createdAt   DateTime      @default(now())

  @@index([transferId])
  @@index([productId])
}

// ════════════════════════════════════════════════════════════════
// SCHEMA RECONCILIATION 2026-04-22 — Issue #23 follow-up
// The 135 models below were added from introspection of the live Neon DB
// to resolve the schema drift documented in prisma/RECONCILE_TODO.md.
//
// All of these tables exist in production but were missing from schema.prisma;
// every access today is via raw SQL. These declarations make the schema a true
// mirror of the DB without changing any runtime behavior. Relations to other
// Prisma models were intentionally stripped to avoid forcing reverse-relation
// additions on stable existing models — these can be added back incrementally.
//
// See prisma/RECONCILE_REPORT_2026_04_22.md for per-table classification.
// ════════════════════════════════════════════════════════════════

