generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── BUILDER ACCOUNTS ────────────────────────────────────────────────

model Builder {
  id            String  @id @default(cuid())
  companyName   String
  contactName   String
  email         String  @unique
  passwordHash  String
  phone         String?
  address       String?
  city          String?
  state         String?
  zip           String?
  licenseNumber String?

  // Two-tier builder classification
  // PRODUCTION = national/regional (Toll, DR Horton) — has communities underneath
  // CUSTOM     = custom home builders — all features centered on builder profile
  builderType   BuilderType @default(CUSTOM)
  territory     String?   // Geographic territory / market
  annualVolume  Int?      // Estimated annual door units
  website       String?

  // Payment & pricing
  paymentTerm    PaymentTerm @default(NET_15)
  creditLimit    Float?
  accountBalance Float       @default(0)
  taxExempt      Boolean     @default(false)
  taxId          String?

  // Status
  status        AccountStatus @default(PENDING)
  emailVerified Boolean       @default(false)
  verifyToken   String?

  // Password reset
  resetToken       String?
  resetTokenExpiry DateTime?

  // QuickBooks Desktop integration
  qbListId  String?   // Customer ListID in QB
  qbSyncedAt DateTime? // Last sync timestamp

  // Relationships
  projects           Project[]
  orders             Order[]
  templates          OrderTemplate[]
  customPricing      BuilderPricing[]
  homeowners         HomeownerAccess[]
  btProjectMappings  BTProjectMapping[]
  referralsSent      BuilderReferral[] @relation("ReferrerReferrals")
  referralsReceived  BuilderReferral[] @relation("ReferredBuilder")

  // Account margin & review
  categoryMargins    AccountCategoryMargin[]
  marginTarget       AccountMarginTarget?

  // Community structure (production builders)
  communities        Community[]
  contacts           BuilderContact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([qbListId])
  @@index([builderType])
}

enum BuilderType {
  PRODUCTION // National/regional builder with communities (Toll, DR Horton, Lennar)
  CUSTOM     // Custom home builder — no community structure
}

enum PaymentTerm {
  PAY_AT_ORDER // 3% discount
  PAY_ON_DELIVERY // Standard price
  NET_15 // 1% premium
  NET_30 // 2.5% premium
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CLOSED
}

// ─── BUILDER COMMUNITIES (Two-Tier Architecture) ────────────────────────
// Production builders (Toll, DR Horton) have Communities underneath.
// Each Community has its own contacts, tasks, comm logs, sales orders,
// performance metrics, blueprints, and pricing — a full picture per community.
// Custom builders skip this layer; everything hangs off the Builder directly.

model Community {
  id        String  @id @default(cuid())
  builderId String
  builder   Builder @relation(fields: [builderId], references: [id], onDelete: Cascade)

  name       String   // "Canyon Ridge Estates", "Sunset Mesa Phase 2"
  code       String?  // Short code: "CRE", "SMP2"
  address    String?
  city       String?
  state      String?
  zip        String?
  county     String?

  // Scope
  totalLots   Int      @default(0)
  activeLots  Int      @default(0)
  phase       String?  // "Phase 1", "Phase 2A"
  status      CommunityStatus @default(ACTIVE)

  // Division (some builders organize by division → community)
  division    String?  // "Dallas Division", "Houston Metro"

  // Performance
  avgOrderValue Float?  // Rolling avg order $
  totalRevenue  Float?  @default(0)
  totalOrders   Int?    @default(0)

  // Notes
  notes       String?

  // Bolt integration
  boltId      String?  // Cross-ref to ECI Bolt community

  // Relationships
  contacts    CommunityContact[]
  floorPlans  CommunityFloorPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([builderId, name])
  @@index([builderId])
  @@index([status])
  @@index([city, state])
  @@index([boltId])
}

enum CommunityStatus {
  PLANNING    // Pre-development
  ACTIVE      // Lots being built / orders flowing
  WINDING_DOWN // Last lots being completed
  CLOSED      // All lots complete, no more orders
}

// ─── BUILDER CONTACTS (people at the builder org) ───────────────────────
// A contact can be org-level (custom builders) or community-level (production)

model BuilderContact {
  id        String  @id @default(cuid())
  builderId String
  builder   Builder @relation(fields: [builderId], references: [id], onDelete: Cascade)

  // Optional community link — if set, this contact is community-specific
  communityId String?
  community   Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)

  firstName    String
  lastName     String
  email        String?
  phone        String?
  mobile       String?
  title        String?  // "Purchasing Manager", "Super", "Division VP"
  role         ContactRole @default(OTHER)

  isPrimary    Boolean @default(false) // Primary contact for this builder or community
  receivesPO   Boolean @default(false) // Gets PO/order notifications
  receivesInvoice Boolean @default(false) // Gets invoice copies

  notes        String?
  active       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([builderId])
  @@index([communityId])
  @@index([email])
  @@index([role])
}

enum ContactRole {
  OWNER           // Builder company owner
  DIVISION_VP     // Division VP (production builders)
  PURCHASING      // Purchasing / procurement
  SUPERINTENDENT  // Field superintendent
  PROJECT_MANAGER // PM on the builder side
  ESTIMATOR       // Builder's estimator
  ACCOUNTS_PAYABLE // AP contact
  OTHER
}

// ─── COMMUNITY FLOOR PLANS ──────────────────────────────────────────────
// Production builders have standard floor plans per community

model CommunityFloorPlan {
  id          String  @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  name         String   // "The Aspen", "Plan 2450"
  planNumber   String?  // Builder's plan number
  sqFootage    Int?
  bedrooms     Int?
  bathrooms    Float?   // 2.5 etc
  stories      Int?     @default(1)
  garageType   String?  // "2-car attached", "3-car"

  // Door package
  interiorDoorCount Int?
  exteriorDoorCount Int?
  basePackagePrice  Float?  // Standard door package price

  // Takeoff reference
  blueprintUrl  String?  // Link to stored blueprint
  takeoffNotes  String?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([communityId, name])
  @@index([communityId])
}

// ─── COMMUNITY NOTES ────────────────────────────────────────────────────
// Linked notes for community-level context (delivery preferences, site rules, etc.)

model CommunityNote {
  id          String  @id @default(cuid())
  communityId String

  authorId    String  // Staff who wrote it
  category    String  @default("GENERAL") // GENERAL, DELIVERY, SITE_ACCESS, QUALITY, PRICING
  content     String
  pinned      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([communityId])
  @@index([category])
}

// ─── BUILDER REFERRALS ──────────────────────────────────────────────────

model BuilderReferral {
  id                String     @id @default(cuid())
  referrerId        String
  referrer          Builder    @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)

  // Referred builder info
  referredCompany   String
  referredContact   String
  referredEmail     String
  referredPhone     String
  referralCode      String     @unique // ABEL-{lastName}-{random4}
  notes             String?

  // Status tracking
  status            ReferralStatus @default(PENDING)
  referredBuilderId String?
  referredBuilder   Builder?   @relation("ReferredBuilder", fields: [referredBuilderId], references: [id], onDelete: SetNull)

  // Credits
  creditAmount      Float      @default(250)
  referrerCredited  Boolean    @default(false)
  referreeCredited  Boolean    @default(false)
  creditedAt        DateTime?

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([referrerId])
  @@index([status])
  @@index([referredBuilderId])
}

enum ReferralStatus {
  PENDING        // Referral submitted, awaiting contact
  CONTACTED      // Referred company has been contacted
  SIGNED_UP      // Referred builder created an account
  FIRST_ORDER    // Referred builder placed first order
  CREDITED       // Both referrer and referee credited
}

// ─── PROJECTS & BLUEPRINTS ───────────────────────────────────────────

model Project {
  id        String  @id @default(cuid())
  builderId String
  builder   Builder @relation(fields: [builderId], references: [id], onDelete: Restrict)

  name        String
  jobAddress  String?
  city        String?
  state       String?
  lotNumber   String?
  subdivision String?
  planName    String?
  sqFootage   Int?

  status ProjectStatus @default(DRAFT)

  // Relationships
  blueprints Blueprint[]
  takeoffs   Takeoff[]
  quotes     Quote[]
  homeowners HomeownerAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([builderId])
  @@index([status])
}

enum ProjectStatus {
  DRAFT
  BLUEPRINT_UPLOADED
  TAKEOFF_PENDING
  TAKEOFF_COMPLETE
  QUOTE_GENERATED
  QUOTE_APPROVED
  ORDERED
  IN_PROGRESS
  DELIVERED
  COMPLETE
}

model Blueprint {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fileName  String
  fileUrl   String
  fileSize  Int
  fileType  String // pdf, png, jpg, dwg
  pageCount Int?

  // AI processing
  processedAt      DateTime?
  processingStatus ProcessingStatus @default(PENDING)

  takeoffs Takeoff[]

  createdAt DateTime @default(now())

  @@index([projectId])
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

// ─── AI TAKEOFF ──────────────────────────────────────────────────────

model Takeoff {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blueprintId String
  blueprint   Blueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)

  status     TakeoffStatus @default(PROCESSING)
  confidence Float? // 0-1 overall confidence score

  // AI results
  rawResult  Json? // Full AI response
  reviewedBy String? // Admin who reviewed
  reviewedAt DateTime?

  items TakeoffItem[]
  quote Quote?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([blueprintId])
  @@index([status])
}

enum TakeoffStatus {
  PROCESSING
  NEEDS_REVIEW
  APPROVED
  REJECTED
}

model TakeoffItem {
  id        String  @id @default(cuid())
  takeoffId String
  takeoff   Takeoff @relation(fields: [takeoffId], references: [id], onDelete: Cascade)

  // What was detected
  category    String // Interior Door, Exterior Door, Trim, Hardware, etc.
  description String // "2068 2-Panel Shaker Hollow Core LH"
  location    String? // "Master Bedroom", "Hallway", etc.
  quantity    Int

  // Matched product
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  // AI confidence
  confidence Float? // 0-1 per-item confidence
  aiNotes    String? // AI reasoning

  // Human overrides
  overridden   Boolean @default(false)
  originalDesc String? // What AI originally detected

  createdAt DateTime @default(now())

  @@index([takeoffId])
  @@index([productId])
  @@index([category])
}

// ─── QUOTES ──────────────────────────────────────────────────────────

model Quote {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  takeoffId String  @unique
  takeoff   Takeoff @relation(fields: [takeoffId], references: [id], onDelete: Cascade)

  quoteNumber String @unique // ABL-2026-0001
  version     Int    @default(1)

  // Pricing
  subtotal       Float
  taxRate        Float @default(0)
  taxAmount      Float @default(0)
  termAdjustment Float @default(0) // Payment term premium/discount
  total          Float

  // Status
  status     QuoteStatus @default(DRAFT)
  validUntil DateTime?
  approvedAt DateTime?
  approvedBy String?

  items QuoteItem[]
  order Order?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([quoteNumber])
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  ORDERED
}

model QuoteItem {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  productId String?  // Nullable for custom line items (delivery fees, misc charges, etc.)
  product   Product? @relation(fields: [productId], references: [id], onDelete: Restrict)

  description String
  quantity    Int
  unitPrice   Float
  lineTotal   Float

  // Upgrade tracking
  isUpgrade     Boolean @default(false)
  baseProductId String? // What it replaced
  upgradeAdder  Float? // Additional cost over base

  // Room/location
  location String?

  sortOrder Int @default(0)

  @@index([quoteId])
  @@index([productId])
}

// ─── ORDERS ──────────────────────────────────────────────────────────

model Order {
  id        String  @id @default(cuid())
  builderId String
  builder   Builder @relation(fields: [builderId], references: [id], onDelete: Restrict)
  quoteId   String? @unique
  quote     Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  orderNumber String  @unique // ORD-2026-0001
  poNumber    String? // Builder's PO number

  // Pricing
  subtotal     Float
  taxAmount    Float @default(0)
  shippingCost Float @default(0)
  total        Float

  // Payment
  paymentTerm   PaymentTerm
  paymentStatus PaymentStatus @default(PENDING)
  paidAt        DateTime?
  dueDate       DateTime?

  // Fulfillment
  status        OrderStatus @default(RECEIVED)
  deliveryDate  DateTime?
  deliveryNotes String?

  // InFlow sync
  inflowOrderId    String? @unique
  inflowCustomerId String?

  items OrderItem[]
  jobs  Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([builderId])
  @@index([orderNumber])
  @@index([status])
}

enum OrderStatus {
  RECEIVED
  CONFIRMED
  IN_PRODUCTION
  AWAITING_MATERIAL   // Some items not in stock — watching for arrival
  READY_TO_SHIP
  PARTIAL_SHIPPED     // Shipped with missing items on backorder
  SHIPPED
  DELIVERED
  COMPLETE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  INVOICED
  PAID
  OVERDUE
  REFUNDED
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  description String
  quantity    Int
  unitPrice   Float
  lineTotal   Float

  @@index([orderId])
  @@index([productId])
}

// ─── ORDER TEMPLATES ─────────────────────────────────────────────────

model OrderTemplate {
  id            String  @id @default(cuid())
  builderId     String
  builder       Builder @relation(fields: [builderId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  sourceOrderId String? // Original order this was created from

  items OrderTemplateItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([builderId])
  @@index([sourceOrderId])
}

model OrderTemplateItem {
  id         String  @id @default(cuid())
  templateId String
  template   OrderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity Int
  notes    String?

  createdAt DateTime @default(now())

  @@index([templateId])
  @@index([productId])
}

// ─── PRODUCT CATALOG ─────────────────────────────────────────────────

model Product {
  id          String  @id @default(cuid())
  sku         String  @unique
  name        String
  displayName String? // Customer-facing product name
  description String?

  // Classification
  category    String // Interior Doors, Exterior Doors, Trim, Hardware
  subcategory String? // Pre-Hung, Slab, Bifold, etc.

  // Pricing
  cost      Float // Abel's cost
  basePrice Float // Standard retail/builder price
  minMargin Float @default(0.25) // 25% floor

  // Attributes (parsed from name)
  doorSize       String? // "2068", "2868"
  handing        String? // LH, RH, LHIS, RHIS
  coreType       String? // Hollow, Solid
  panelStyle     String? // 2-Panel, 6-Panel, Shaker, Flat
  jambSize       String? // 4-9/16, 6-9/16
  casingCode     String? // A-Col, C-322
  hardwareFinish String? // SN, BLK, ORB
  material       String? // Pine, MDF, Primed
  fireRating     String? // 20min, 45min, 90min

  // Images
  imageUrl     String? // Primary product image URL
  thumbnailUrl String? // Smaller thumbnail for lists/grids
  imageAlt     String? // Alt text for accessibility

  // Status
  active       Boolean @default(true)
  inStock      Boolean @default(true)
  leadTimeDays Int?

  // InFlow sync
  inflowId       String?
  inflowCategory String?
  lastSyncedAt   DateTime?

  // Relationships
  takeoffItems     TakeoffItem[]
  quoteItems       QuoteItem[]
  orderItems       OrderItem[]
  templateItems    OrderTemplateItem[]
  bomParent        BomEntry[]       @relation("BomParent")
  bomComponent     BomEntry[]       @relation("BomComponent")
  builderPrices    BuilderPricing[]
  upgradeFrom      UpgradePath[]    @relation("UpgradeFrom")
  upgradeTo        UpgradePath[]    @relation("UpgradeTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sku])
  @@index([category])
  @@index([active])
}

model BomEntry {
  id          String  @id @default(cuid())
  parentId    String
  parent      Product @relation("BomParent", fields: [parentId], references: [id], onDelete: Cascade)
  componentId String
  component   Product @relation("BomComponent", fields: [componentId], references: [id], onDelete: Cascade)

  quantity      Float   @default(1)
  componentType String? // Slab, Jamb, Casing, Hinge, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([componentId])
}

model BuilderPricing {
  id        String  @id @default(cuid())
  builderId String
  builder   Builder @relation(fields: [builderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  customPrice Float
  margin      Float? // Calculated margin at this price

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([builderId, productId])
  @@index([builderId])
  @@index([productId])
}

model UpgradePath {
  id            String  @id @default(cuid())
  fromProductId String
  fromProduct   Product @relation("UpgradeFrom", fields: [fromProductId], references: [id], onDelete: Cascade)
  toProductId   String
  toProduct     Product @relation("UpgradeTo", fields: [toProductId], references: [id], onDelete: Cascade)

  upgradeType String // door_style, hardware, core, finish
  costDelta   Float // Difference in cost
  priceDelta  Float // Suggested price adder
  description String? // "Upgrade from Hollow Core to Solid Core"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fromProductId, toProductId])
  @@index([fromProductId])
  @@index([toProductId])
}

// ─── HOMEOWNER PORTAL ────────────────────────────────────────────────

model HomeownerAccess {
  id        String  @id @default(cuid())
  builderId String
  builder   Builder @relation(fields: [builderId], references: [id], onDelete: Cascade)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Homeowner info
  name        String
  email       String
  phone       String?
  accessToken String  @unique // URL token for portal access

  // Selection tracking
  selections HomeownerSelection[]

  // Status
  active      Boolean   @default(true)
  expiresAt   DateTime?
  lastVisitAt DateTime?

  createdAt DateTime @default(now())

  @@index([accessToken])
  @@index([projectId])
  @@index([builderId])
  @@index([email])
  @@index([active])
}

model HomeownerSelection {
  id                String          @id @default(cuid())
  homeownerAccessId String
  homeownerAccess   HomeownerAccess @relation(fields: [homeownerAccessId], references: [id], onDelete: Cascade)

  location          String // "Master Bedroom Door"
  baseProductId     String // The default/base product
  selectedProductId String // What the homeowner picked
  adderCost         Float // Cost difference to homeowner

  status      SelectionStatus @default(PENDING)
  confirmedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([homeownerAccessId])
  @@index([status])
}

enum SelectionStatus {
  PENDING
  CONFIRMED
  LOCKED
}

// ═══════════════════════════════════════════════════════════════════════
// PM / CRM / ERP MODULE
// Based on Abel SOP frameworks & Module 2 Systems Training
// ═══════════════════════════════════════════════════════════════════════

// ─── STAFF & ROLES ──────────────────────────────────────────────────

model Staff {
  id           String     @id @default(cuid())
  firstName    String
  lastName     String
  email        String     @unique
  passwordHash String
  phone        String?
  role         StaffRole  // Primary role (backward compat)
  roles        String?    // Comma-separated list of ALL roles (multi-role support): "ADMIN,MANAGER,PROJECT_MANAGER"
  department   Department
  title        String? // "Project Manager", "Manufacturing Lead", etc.
  avatar       String? // Profile image URL
  active       Boolean    @default(true)
  hireDate     DateTime?

  // Portal access overrides (JSON format): { "/ops/jobs": true, "/ops/finance": false }
  // true = explicitly GRANT access (even if role doesn't have it)
  // false = explicitly DENY access (even if role has it)
  // missing = use role-based default
  portalOverrides Json?    @default("{}")

  // Relationships
  assignedJobs         Job[]                     @relation("AssignedPM")
  activities           Activity[]
  tasks                Task[]                    @relation("TaskAssignee")
  tasksCreated         Task[]                    @relation("TaskCreator")
  crewMembership       CrewMember[]
  decisionNotes        DecisionNote[]
  purchaseOrders       PurchaseOrder[]           @relation("POCreator")
  poApprovals          PurchaseOrder[]           @relation("POApprover")
  invoicesCreated      Invoice[]
  qualityChecks        QualityCheck[]
  notifications        Notification[]            @relation("StaffNotifications")
  conversations        ConversationParticipant[] @relation("ConversationParticipants")
  messagesSent         Message[]                 @relation("MessagesSent")
  conversationsCreated Conversation[]            @relation("ConversationCreator")

  // Sales
  ownedDeals           Deal[]                    @relation("DealOwner")
  dealActivities       DealActivity[]            @relation("DealActivities")
  contractsCreated     Contract[]                @relation("ContractCreator")
  documentRequests     DocumentRequest[]         @relation("DocRequester")

  // Compensation
  hourlyRate Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([department])
  @@index([active])
}

enum StaffRole {
  ADMIN // Full system access
  MANAGER // Department manager
  PROJECT_MANAGER // PM - runs accounts & jobs
  ESTIMATOR // Pricing & takeoff review
  SALES_REP // Account acquisition
  PURCHASING // Vendor & PO management
  WAREHOUSE_LEAD // Manufacturing floor lead
  WAREHOUSE_TECH // Door line worker
  DRIVER // Delivery crew
  INSTALLER // Field install crew
  QC_INSPECTOR // Quality control
  ACCOUNTING // AR/AP/Invoicing
  VIEWER // Read-only access
}

enum Department {
  EXECUTIVE
  SALES
  ESTIMATING
  OPERATIONS
  MANUFACTURING
  WAREHOUSE
  DELIVERY
  INSTALLATION
  ACCOUNTING
  PURCHASING
}

// ─── JOBS (Operational unit — links Quote/Order to field work) ───────
// A "Job" is the ops-side representation of a project drop/delivery
// Maps to ECI Bolt's job concept with Lot-Block-Community identifiers

model Job {
  id          String  @id @default(cuid())
  jobNumber   String  @unique // e.g., "JOB-2026-0142"
  boltJobId   String? // Cross-ref to ECI Bolt
  inflowJobId String? // Cross-ref to InFlow

  // Builder & project link
  orderId   String?
  order     Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  projectId String?
  // Not adding direct Project relation to avoid circular deps; use orderId->quote->project

  // Job identifiers (from Module 2 — Lot-Block system)
  lotBlock       String? // "Lot 14 Block 3"
  community      String? // "Canyon Ridge" (denormalized for quick display)
  communityId    String? // FK to Community table (if production builder)
  builderName    String // Denormalized for quick display
  builderContact String?
  jobAddress     String?
  bwpPoNumber    String? // Builder's PO number

  // Scope
  scopeType ScopeType
  dropPlan  String? // "Single Drop", "Staged", "Multi-Drop"

  // Assignment
  assignedPMId String?
  assignedPM   Staff?  @relation("AssignedPM", fields: [assignedPMId], references: [id], onDelete: SetNull)

  // Status tracking (from Module 2 T-72/T-48/T-24 workflow)
  status          JobStatus @default(CREATED)
  readinessCheck  Boolean   @default(false) // T-72 readiness confirmed
  materialsLocked Boolean   @default(false) // T-48 materials locked
  loadConfirmed   Boolean   @default(false) // T-24 truck loaded
  scheduledDate   DateTime? // Target delivery/install date
  actualDate      DateTime?
  completedAt     DateTime?

  // Relationships
  decisionNotes      DecisionNote[]
  scheduleEntries    ScheduleEntry[]
  materialPicks      MaterialPick[]
  qualityChecks      QualityCheck[]
  deliveries         Delivery[]
  installations      Installation[]
  tasks              Task[]
  activities         Activity[]
  btProjectMappings  BTProjectMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([assignedPMId])
  @@index([scheduledDate])
  @@index([builderName])
  @@index([community])
  @@index([communityId])
  @@index([orderId])
}

enum JobStatus {
  CREATED
  READINESS_CHECK // T-72: materials & specs being verified
  MATERIALS_LOCKED // T-48: materials confirmed in InFlow
  IN_PRODUCTION // Manufacturing/assembly
  STAGED // Warehouse staging complete
  LOADED // On truck
  IN_TRANSIT // Delivery en route
  DELIVERED // On site
  INSTALLING // Install crew working
  PUNCH_LIST // Fixes/touch-ups needed
  COMPLETE // All work done
  INVOICED // Invoice sent
  CLOSED // Payment received, job archived
}

enum ScopeType {
  DOORS_ONLY
  TRIM_ONLY
  DOORS_AND_TRIM
  HARDWARE_ONLY
  FULL_PACKAGE // Doors + trim + hardware + install
  CUSTOM
}

// ─── DECISION NOTES (from Module 2 — ECI Bolt SOPs) ────────────────
// Standardized communication log for each job with typed prefixes

model DecisionNote {
  id       String @id @default(cuid())
  jobId    String
  job      Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  authorId String
  author   Staff  @relation(fields: [authorId], references: [id], onDelete: Restrict)

  noteType DecisionNoteType
  subject  String // Brief summary
  body     String // Full note content (BLUF format)
  priority NotePriority     @default(NORMAL)

  // Linked artifacts
  attachmentUrl String?
  relatedTaskId String?

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([noteType])
  @@index([authorId])
  @@index([priority])
}

enum DecisionNoteType {
  READINESS // [READINESS] — T-72 check
  LOCK // [LOCK] — Materials locked
  ARRIVED // [ARRIVED] — Material arrived
  COMPLETE // [COMPLETE] — Job completed
  EXCEPTION // [EXCEPTION] — Issue found
  ESCALATION // [ESCALATION] — Needs manager attention
  APPROVAL // [APPROVAL] — Pricing/change approved
  CLOSEOUT // [CLOSEOUT] — Job closing notes
  GENERAL // General note
}

enum NotePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ─── ACTIVITIES (CRM interaction log) ───────────────────────────────

model Activity {
  id      String @id @default(cuid())
  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Restrict)

  // Polymorphic link — activity can relate to a builder, community, job, or combo
  builderId   String?
  communityId String? // Link to community for production builders
  jobId       String?
  job         Job?    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  activityType ActivityType
  subject      String
  notes        String?
  outcome      String? // "Left voicemail", "Agreed to NET_15", etc.

  // Scheduling
  scheduledAt  DateTime?
  completedAt  DateTime?
  durationMins Int?

  createdAt DateTime @default(now())

  @@index([builderId])
  @@index([communityId])
  @@index([jobId])
  @@index([staffId])
  @@index([activityType])
  @@index([scheduledAt])
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  SITE_VISIT
  TEXT_MESSAGE
  NOTE
  QUOTE_SENT
  QUOTE_FOLLOW_UP
  ISSUE_REPORTED
  ISSUE_RESOLVED
}

// ─── TASKS (PM action items & follow-ups) ───────────────────────────

model Task {
  id String @id @default(cuid())

  // Assignment
  assigneeId String
  assignee   Staff  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  creatorId  String
  creator    Staff  @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Restrict)

  // Context
  jobId       String?
  job         Job?    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  builderId   String?
  communityId String? // Link to community for production builders

  // Task details
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  category    TaskCategory @default(GENERAL)

  dueDate     DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assigneeId])
  @@index([jobId])
  @@index([status])
  @@index([dueDate])
  @@index([creatorId])
  @@index([builderId])
  @@index([communityId])
  @@index([priority])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum TaskCategory {
  GENERAL
  READINESS_CHECK
  MATERIAL_VERIFICATION
  BUILDER_COMMUNICATION
  CREW_DISPATCH
  QUALITY_REVIEW
  INVOICE_FOLLOW_UP
  SCHEDULING
  EXCEPTION_RESOLUTION
}

// ─── SCHEDULING & DISPATCH ──────────────────────────────────────────

model ScheduleEntry {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  entryType     ScheduleType
  title         String
  scheduledDate DateTime
  scheduledTime String? // "8:00 AM", "Morning", "PM"

  // Assignment
  crewId String?
  crew   Crew?   @relation(fields: [crewId], references: [id], onDelete: SetNull)

  status ScheduleStatus @default(TENTATIVE)
  notes  String?

  // Actual timing
  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduledDate])
  @@index([crewId])
  @@index([status])
  @@index([jobId])
}

enum ScheduleType {
  DELIVERY
  INSTALLATION
  PICKUP
  RETURN
  INSPECTION
  RESTOCKING
}

enum ScheduleStatus {
  TENTATIVE // Planned but not confirmed
  FIRM // Confirmed with crew & builder
  IN_PROGRESS
  COMPLETED
  RESCHEDULED
  CANCELLED
}

// ─── CREWS (Delivery & Install teams) ───────────────────────────────

model Crew {
  id       String   @id @default(cuid())
  name     String // "Delivery Team A", "Install Crew - Sean"
  crewType CrewType
  active   Boolean  @default(true)

  // Vehicle (for delivery crews)
  vehicleId    String?
  vehiclePlate String?

  members         CrewMember[]
  scheduleEntries ScheduleEntry[]
  deliveries      Delivery[]
  installations   Installation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

enum CrewType {
  DELIVERY
  INSTALLATION
  DELIVERY_AND_INSTALL
}

model CrewMember {
  id      String @id @default(cuid())
  crewId  String
  crew    Crew   @relation(fields: [crewId], references: [id], onDelete: Cascade)
  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  role    String @default("Member") // "Lead", "Member", "Driver"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([crewId, staffId])
  @@index([crewId])
  @@index([staffId])
}

// ─── DELIVERIES (from Delivery Crew SOP) ────────────────────────────

model Delivery {
  id     String  @id @default(cuid())
  jobId  String
  job    Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  crewId String?
  crew   Crew?   @relation(fields: [crewId], references: [id], onDelete: SetNull)

  // Route
  deliveryNumber String @unique // "DEL-2026-0089"
  routeOrder     Int    @default(0)
  address        String

  // Execution
  status      DeliveryStatus @default(SCHEDULED)
  departedAt  DateTime?
  arrivedAt   DateTime?
  completedAt DateTime?

  // Documentation (from SOP — photo requirements)
  loadPhotos String[] // URLs to load confirmation photos
  sitePhotos String[] // URLs to on-site drop photos
  signedBy   String? // Who signed for delivery

  // Issues
  damageNotes String?
  returnItems String? // Items refused or damaged

  notes String?

  // Tracking updates
  tracking DeliveryTracking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([status])
  @@index([crewId])
  @@index([deliveryNumber])
}

enum DeliveryStatus {
  SCHEDULED
  LOADING
  IN_TRANSIT
  ARRIVED
  UNLOADING
  COMPLETE
  PARTIAL_DELIVERY
  REFUSED
  RESCHEDULED
}

// ─── DELIVERY TRACKING (Real-time delivery status updates) ────────────

model DeliveryTracking {
  id          String   @id @default(cuid())
  deliveryId  String
  delivery    Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  status      String   // PICKING, LOADED, DEPARTED, EN_ROUTE, NEARBY, ARRIVED, UNLOADING, COMPLETE
  location    String?  // Current location/address
  notes       String?  // Additional notes
  eta         DateTime? // Estimated time of arrival
  updatedBy   String   // Staff ID of who made the update

  timestamp   DateTime @default(now())

  @@index([deliveryId])
  @@index([timestamp])
  @@index([status])
}

// ─── INSTALLATIONS (from PM SOP — field work tracking) ──────────────

model Installation {
  id     String  @id @default(cuid())
  jobId  String
  job    Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  crewId String?
  crew   Crew?   @relation(fields: [crewId], references: [id], onDelete: SetNull)

  installNumber String  @unique // "INS-2026-0063"
  scopeNotes    String? // What's being installed

  status        InstallationStatus @default(SCHEDULED)
  scheduledDate DateTime?
  startedAt     DateTime?
  completedAt   DateTime?

  // Quality
  passedQC   Boolean @default(false)
  punchItems String? // Punch list items if any

  // Documentation
  beforePhotos String[]
  afterPhotos  String[]

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([status])
  @@index([crewId])
  @@index([installNumber])
}

enum InstallationStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETE
  PUNCH_LIST
  REWORK
  CANCELLED
}

// ─── QUALITY CONTROL (from Manufacturing SOP) ───────────────────────

model QualityCheck {
  id          String  @id @default(cuid())
  jobId       String?
  job         Job?    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  inspectorId String
  inspector   Staff   @relation(fields: [inspectorId], references: [id], onDelete: Restrict)

  checkType   QCType
  result      QCResult
  notes       String?
  defectCodes String[] // Standard defect codes

  // Photos
  photos String[]

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([checkType])
  @@index([inspectorId])
  @@index([result])
}

enum QCType {
  PRE_PRODUCTION // Before assembly
  IN_PROCESS // During manufacturing
  FINAL_UNIT // After assembly, before staging
  PRE_DELIVERY // Load check
  POST_INSTALL // On-site quality
}

enum QCResult {
  PASS
  FAIL
  CONDITIONAL_PASS // Minor issues noted but acceptable
}

// ─── PURCHASING & INVENTORY ─────────────────────────────────────────

model Vendor {
  id            String  @id @default(cuid())
  name          String // "DW Distribution", "Boise Cascade"
  code          String  @unique // "DW", "BC", "MASO"
  contactName   String?
  email         String?
  phone         String?
  address       String?
  website       String?
  accountNumber String? // Abel's account # with this vendor

  // Performance
  avgLeadDays Int?
  onTimeRate  Float? // 0-1

  active Boolean @default(true)

  // InFlow sync
  inflowVendorId String? @unique

  purchaseOrders PurchaseOrder[]
  vendorProducts VendorProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([active])
  @@index([inflowVendorId])
}

// Maps products to their vendor/supplier catalog entries
model VendorProduct {
  id        String @id @default(cuid())
  vendorId  String
  vendor    Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  productId String
  // Not adding direct Product relation to keep migration clean

  vendorSku    String // Vendor's own SKU
  vendorName   String? // Vendor's product name
  vendorCost   Float? // What we pay the vendor
  minOrderQty  Int     @default(1)
  leadTimeDays Int?
  preferred    Boolean @default(false) // Is this the preferred vendor for this product?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendorId, productId])
  @@index([productId])
  @@index([vendorId])
  @@index([preferred])
}

model PurchaseOrder {
  id       String @id @default(cuid())
  poNumber String @unique // "PO-2026-0451"
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  createdById  String
  createdBy    Staff   @relation("POCreator", fields: [createdById], references: [id], onDelete: Restrict)
  approvedById String?
  approvedBy   Staff?  @relation("POApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  status       POStatus @default(DRAFT)
  subtotal     Float    @default(0)
  shippingCost Float    @default(0)
  total        Float    @default(0)

  // Dates
  orderedAt    DateTime?
  expectedDate DateTime? // Expected delivery from vendor
  receivedAt   DateTime?

  notes String?

  // QuickBooks Desktop integration
  qbTxnId String?   // Bill TxnID in QB
  qbSyncedAt DateTime? // Last sync timestamp

  // InFlow sync
  inflowId       String? @unique
  inflowVendorId String?

  items PurchaseOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
  @@index([status])
  @@index([qbTxnId])
  @@index([createdById])
  @@index([approvedById])
  @@index([orderedAt])
}

enum POStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT_TO_VENDOR
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  productId   String? // Link to Abel product if applicable
  vendorSku   String
  description String
  quantity    Int
  unitCost    Float
  lineTotal   Float

  // Receiving
  receivedQty Int @default(0)
  damagedQty  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purchaseOrderId])
  @@index([productId])
}

// ─── INVENTORY TRACKING ─────────────────────────────────────────────

model InventoryItem {
  id        String @id @default(cuid())
  productId String @unique
  // Product relation not added to keep migration simple; join by productId

  // Denormalized product info (for fast queries without joins)
  sku         String?
  productName String?
  category    String?

  // Stock levels
  onHand    Int @default(0)
  committed Int @default(0) // Reserved for jobs
  onOrder   Int @default(0) // On purchase orders
  available Int @default(0) // onHand - committed

  // Thresholds
  reorderPoint Int @default(0)
  reorderQty   Int @default(0)
  safetyStock  Int @default(5)
  maxStock     Int @default(200)

  // Cost & usage tracking
  unitCost      Float   @default(0)
  avgDailyUsage Float   @default(0)
  daysOfSupply  Float   @default(0)

  // Location
  warehouseZone String? // "A1", "B3", "Staging"
  binLocation   String? // "Shelf 4 Row 2"
  location      String  @default("MAIN_WAREHOUSE")

  // Status
  status String @default("IN_STOCK")

  lastCountedAt  DateTime?
  lastReceivedAt DateTime?

  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([sku])
  @@index([category])
  @@index([status])
  @@index([lastReceivedAt])
  @@index([warehouseZone])
}

// ─── INVOICING & AR ─────────────────────────────────────────────────

model Invoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique // "INV-2026-1234"
  builderId     String
  // Builder relation not added to keep migration simple

  orderId String?
  jobId   String?

  createdById String
  createdBy   Staff  @relation(fields: [createdById], references: [id], onDelete: Restrict)

  // Amounts
  subtotal   Float
  taxAmount  Float @default(0)
  total      Float
  amountPaid Float @default(0)
  balanceDue Float

  // Status & payment
  status      InvoiceStatus @default(DRAFT)
  paymentTerm PaymentTerm
  issuedAt    DateTime?
  dueDate     DateTime?
  paidAt      DateTime?

  notes String?

  // QuickBooks Desktop integration
  qbTxnId String?   // Invoice TxnID in QB
  qbSyncedAt DateTime? // Last sync timestamp
  qbSyncStatus String? // PENDING, SYNCED, FAILED

  items              InvoiceItem[]
  payments           Payment[]
  collectionActions  CollectionAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([builderId])
  @@index([status])
  @@index([dueDate])
  @@index([qbTxnId])
  @@index([qbSyncStatus])
  @@index([createdById])
  @@index([orderId])
  @@index([issuedAt])
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  WRITE_OFF
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId   String?
  description String
  quantity    Int
  unitPrice   Float
  lineTotal   Float

  @@index([invoiceId])
  @@index([productId])
}

model Payment {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount     Float
  method     PaymentMethod
  reference  String? // Check number, transaction ID
  receivedAt DateTime      @default(now())
  notes      String?

  @@index([invoiceId])
  @@index([receivedAt])
  @@index([method])
}

enum PaymentMethod {
  CHECK
  ACH
  WIRE
  CREDIT_CARD
  CASH
  OTHER
}

// ─── MATERIAL PICKS (from InFlow SOP — Pre-Drop checks) ────────────

model MaterialPick {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  productId   String?
  sku         String
  description String
  quantity    Int
  pickedQty   Int     @default(0)

  status     PickStatus @default(PENDING)
  zone       String? // Warehouse zone
  pickedAt   DateTime?
  verifiedAt DateTime?

  notes String?

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([status])
  @@index([productId])
  @@index([pickedAt])
  @@index([zone])
}

enum PickStatus {
  PENDING
  PICKING
  PICKED
  VERIFIED
  SHORT // Not enough stock
  SUBSTITUTED // Different product pulled
}

// ─── ENUMS FOR MESSAGING & NOTIFICATIONS ────────────────────────

enum ConversationType {
  DIRECT
  GROUP
  CHANNEL
  DEPARTMENT
}

enum NotificationType {
  JOB_UPDATE
  TASK_ASSIGNED
  MESSAGE
  PO_APPROVAL
  DELIVERY_UPDATE
  QC_ALERT
  INVOICE_OVERDUE
  SCHEDULE_CHANGE
  MATERIAL_ARRIVAL    // Watched material has arrived at warehouse
  BACKORDER_UPDATE    // Backorder status change
  OUTREACH_REVIEW     // Outreach step ready for review
  SYSTEM
}

// ─── MESSAGING (Internal staff communication) ───────────────────

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         Staff        @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Restrict)

  body   String
  readBy String[] // Array of staff IDs who read it

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model Conversation {
  id              String           @id @default(cuid())
  type            ConversationType
  name            String? // For groups/channels
  departmentScope String? // Department name for department channels (e.g. "EXECUTIVE", "SALES")

  createdById String
  createdBy   Staff  @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: Restrict)

  participants ConversationParticipant[]
  messages     Message[]

  lastMessageAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([createdById])
  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  staffId        String
  staff          Staff        @relation("ConversationParticipants", fields: [staffId], references: [id], onDelete: Cascade)

  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  @@unique([conversationId, staffId])
  @@index([conversationId])
  @@index([staffId])
}

model Notification {
  id      String @id @default(cuid())
  staffId String
  staff   Staff  @relation("StaffNotifications", fields: [staffId], references: [id], onDelete: Cascade)

  type  NotificationType
  title String
  body  String
  link  String? // URL to navigate to
  read  Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([staffId])
  @@index([read])
  @@index([type])
  @@index([createdAt])
}

// ─── SALES PIPELINE & DEALS ─────────────────────────────────────────
// Full CRM pipeline for sales reps to track prospects through to close

model Deal {
  id         String @id @default(cuid())
  dealNumber String @unique // e.g., "DEAL-2026-0042"

  // Prospect / Builder info
  companyName  String
  contactName  String
  contactEmail String?
  contactPhone String?
  address      String?
  city         String?
  state        String?
  zip          String?

  // Pipeline
  stage       DealStage    @default(PROSPECT)
  probability Int          @default(10) // 0-100% win probability
  dealValue   Float        @default(0) // Estimated annual revenue
  source      DealSource   @default(OUTBOUND)

  // Dates
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  lostDate          DateTime?
  lostReason        String?

  // Assignment
  ownerId String
  owner   Staff  @relation("DealOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  // Link to builder once converted
  builderId String?

  // Notes
  description String? // What they build, territory, volume, etc.
  notes       String?

  // Relationships
  activities     DealActivity[]
  contracts      Contract[]
  documentRequests DocumentRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([stage])
  @@index([builderId])
  @@index([expectedCloseDate])
  @@index([dealNumber])
  @@index([source])
  @@index([probability])
}

enum DealStage {
  PROSPECT        // Initial lead — not yet contacted
  DISCOVERY       // First contact made, gathering info
  WALKTHROUGH     // Site walkthrough or showroom visit scheduled/done
  BID_SUBMITTED   // Formal bid/proposal sent
  BID_REVIEW      // Builder reviewing bid
  NEGOTIATION     // Active negotiation on terms/pricing
  WON             // Deal closed — moving to onboarding
  LOST            // Deal lost to competitor or abandoned
  ONBOARDED       // Builder fully set up on platform
}

enum DealSource {
  OUTBOUND     // Rep cold outreach
  REFERRAL     // Referred by existing builder
  INBOUND      // Builder inquired via website/phone
  TRADE_SHOW   // Met at trade show / event
  REACTIVATION // Previous customer re-engagement
}

// ─── DEAL ACTIVITY LOG ──────────────────────────────────────────────

model DealActivity {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  staffId String
  staff   Staff  @relation("DealActivities", fields: [staffId], references: [id], onDelete: Restrict)

  type    DealActivityType
  subject String
  notes   String?
  outcome String?

  // Follow-up scheduling
  followUpDate DateTime?
  followUpDone Boolean   @default(false)

  createdAt DateTime @default(now())

  @@index([dealId])
  @@index([staffId])
  @@index([type])
  @@index([followUpDate])
  @@index([followUpDone])
  @@index([createdAt])
}

enum DealActivityType {
  CALL
  EMAIL
  MEETING
  SITE_VISIT
  TEXT
  NOTE
  STAGE_CHANGE
  BID_SENT
  BID_REVISED
  CONTRACT_SENT
  CONTRACT_SIGNED
  DOCUMENT_REQUESTED
  DOCUMENT_RECEIVED
  FOLLOW_UP
}

// ─── CONTRACTS ──────────────────────────────────────────────────────

model Contract {
  id             String @id @default(cuid())
  contractNumber String @unique // e.g., "CTR-2026-0015"

  dealId    String?
  deal      Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)
  builderId String?

  // Contract details
  title           String
  type            ContractType     @default(SUPPLY_AGREEMENT)
  status          ContractStatus   @default(DRAFT)

  // Financial terms
  paymentTerm     PaymentTerm?
  creditLimit     Float?
  estimatedAnnual Float?           // Estimated annual volume
  discountPercent Float?           // Negotiated discount

  // Content
  terms           String?          // Contract terms text
  specialClauses  String?          // Special conditions

  // Dates
  startDate       DateTime?
  endDate         DateTime?
  sentDate        DateTime?
  signedDate      DateTime?
  expiresDate     DateTime?

  // People
  createdById String?
  createdBy   Staff?  @relation("ContractCreator", fields: [createdById], references: [id], onDelete: SetNull)

  // File
  documentUrl     String?          // Uploaded signed contract PDF
  templateUsed    String?          // Which template was used

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([builderId])
  @@index([status])
  @@index([createdById])
  @@index([contractNumber])
  @@index([signedDate])
}

enum ContractType {
  SUPPLY_AGREEMENT    // Standard supply agreement
  MASTER_SERVICE      // Master service agreement
  PRICING_AGREEMENT   // Custom pricing terms
  NDA                 // Non-disclosure agreement
  CREDIT_APPLICATION  // Credit application
}

enum ContractStatus {
  DRAFT               // Being prepared
  INTERNAL_REVIEW     // Internal review before sending
  SENT                // Sent to builder for review
  BUILDER_REVIEW      // Builder reviewing
  REVISION_REQUESTED  // Builder requested changes
  SIGNED              // Both parties signed
  ACTIVE              // Currently active
  EXPIRED             // Past end date
  TERMINATED          // Early termination
}

// ─── DOCUMENT REQUESTS (COI, W-9, Credit Apps, etc.) ────────────────

model DocumentRequest {
  id        String @id @default(cuid())

  dealId    String?
  deal      Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)
  builderId String?

  // What's needed
  documentType  DocumentType
  title         String
  description   String?

  // Status tracking
  status        DocumentRequestStatus @default(PENDING)

  // Who's involved
  requestedById String
  requestedBy   Staff  @relation("DocRequester", fields: [requestedById], references: [id], onDelete: Restrict)

  // File tracking
  fileUrl       String?     // Uploaded document URL
  fileName      String?

  // Dates
  dueDate       DateTime?
  receivedDate  DateTime?
  expiresDate   DateTime?   // For COIs and other expiring docs

  // Follow-up
  reminderSent  Boolean @default(false)
  reminderDate  DateTime?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([builderId])
  @@index([status])
  @@index([documentType])
  @@index([requestedById])
  @@index([dueDate])
  @@index([expiresDate])
  @@index([reminderSent])
}

enum DocumentType {
  COI                  // Certificate of Insurance
  W9                   // W-9 Tax Form
  CREDIT_APPLICATION   // Credit application
  BUSINESS_LICENSE     // Business license
  TAX_EXEMPT_CERT      // Tax exemption certificate
  BOND                 // Surety bond
  REFERENCES           // Trade/credit references
  FINANCIAL_STATEMENT  // Financial statement
  OTHER                // Custom document
}

enum DocumentRequestStatus {
  PENDING     // Requested, not yet sent to builder
  SENT        // Request sent to builder
  RECEIVED    // Document received
  APPROVED    // Document reviewed and approved
  REJECTED    // Document rejected (needs resubmission)
  EXPIRED     // Document has expired
}

// ─── QUICKBOOKS DESKTOP INTEGRATION ───────────────────────────────────────

model QBSyncQueue {
  id           String    @id @default(cuid())
  action       String    // CUSTOMER_ADD, INVOICE_ADD, PO_ADD, PAYMENT_ADD
  entityType   String    // BUILDER, INVOICE, PO, PAYMENT
  entityId     String    // ID of the entity being synced
  qbTxnId      String?   // QB Transaction ID (from response)
  qbListId     String?   // QB List ID (from response)
  requestXml   String?   // qbXML request sent to QB
  responseXml  String?   // qbXML response from QB
  payload      Json?     // Additional data needed for sync
  status       String    @default("pending") // pending, processing, completed, failed
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  lastError    String?
  processedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([status])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@index([action])
  @@index([attempts])
}

model SyncLog {
  id              String    @id @default(cuid())
  provider        String    // QUICKBOOKS_DESKTOP, INFLOW, etc.
  syncType        String    // CUSTOMER_ADD, INVOICE_ADD, etc. or 'full'
  direction       String    @default("PUSH") // PUSH, PULL, BIDIRECTIONAL
  status          String    // SUCCESS, PARTIAL, FAILED
  recordsProcessed Int      @default(0)
  recordsCreated  Int       @default(0)
  recordsUpdated  Int       @default(0)
  recordsSkipped  Int       @default(0)
  recordsFailed   Int       @default(0)
  errorMessage    String?
  startedAt       DateTime
  completedAt     DateTime
  durationMs      Int

  createdAt DateTime @default(now())

  @@index([provider])
  @@index([status])
  @@index([startedAt])
  @@index([syncType])
  @@index([completedAt])
}

// ─── INTEGRATION CONFIGURATION ────────────────────────────────────────────

enum IntegrationProvider {
  INFLOW
  ECI_BOLT
  GMAIL
  HYPHEN
  QUICKBOOKS_DESKTOP
  BUILDERTREND
}

enum IntegrationStatus {
  PENDING        // Not yet configured
  CONFIGURING    // Config being tested
  CONNECTED      // Successfully authenticated
  DISCONNECTED   // Explicitly disconnected
  ERROR          // Connection failed
}

model IntegrationConfig {
  id                String                @id @default(cuid())
  provider          IntegrationProvider
  name              String?
  apiKey            String?               // OAuth2 client_id, API key, etc.
  apiSecret         String?               // OAuth2 client_secret, API secret, etc.
  accessToken       String?               // OAuth2 access token
  refreshToken      String?               // OAuth2 refresh token
  tokenExpiresAt    DateTime?             // Access token expiration
  baseUrl           String?               // API base URL
  companyId         String?               // Company/tenant ID in the external system
  webhookSecret     String?               // Secret for webhook signature verification
  syncEnabled       Boolean               @default(true)
  syncInterval      Int                   @default(3600) // Seconds between auto-syncs
  status            IntegrationStatus     @default(PENDING)
  lastSyncAt        DateTime?
  lastSyncStatus    String?               // SUCCESS, PARTIAL, FAILED
  metadata          Json?                 // Provider-specific metadata
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([provider])
  @@index([status])
  @@index([lastSyncAt])
  @@index([syncEnabled])
  @@index([syncInterval])
}

// ─── BUILDERTREND PROJECT MAPPING ────────────────────────────────────────

model BTProjectMapping {
  id                String     @id @default(cuid())

  // BuilderTrend project info
  btProjectId       String     @unique
  btProjectName     String
  btBuilderName     String?
  btCommunity       String?
  btLot             String?
  btBlock           String?
  btStatus          String     // ACTIVE, COMPLETED, ARCHIVED, etc.
  btScheduleData    Json?      // Cached schedule data from BT

  // Abel mapping
  builderId         String?
  builder           Builder?   @relation(fields: [builderId], references: [id], onDelete: SetNull)
  projectId         String?
  // Note: No direct Project relation to avoid circular dependencies; use through Order/Quote
  jobId             String?
  job               Job?       @relation(fields: [jobId], references: [id], onDelete: SetNull)

  // Sync tracking
  lastSyncedAt      DateTime?

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([builderId])
  @@index([jobId])
  @@index([btStatus])
  @@index([lastSyncedAt])
  @@index([btProjectId])
}

// ─── COLLECTIONS WORKFLOW ───────────────────────────────────────

model CollectionRule {
  id            String   @id @default(cuid())
  name          String
  daysOverdue   Int      // Trigger this rule when invoice is X days overdue
  actionType    String   // REMINDER, PAST_DUE, FINAL_NOTICE, ACCOUNT_HOLD, PHONE_CALL, PAYMENT_PLAN
  channel       String   // EMAIL, SMS, PHONE, LETTER
  templateBody  String?  // Email template body
  isActive      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([daysOverdue])
  @@index([isActive])
  @@index([actionType])
}

model CollectionAction {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  actionType String   // REMINDER, PAST_DUE, FINAL_NOTICE, ACCOUNT_HOLD, PHONE_CALL, PAYMENT_PLAN
  channel    String   // EMAIL, SMS, PHONE, LETTER
  sentAt     DateTime @default(now())
  sentBy     String?  // Staff member ID who sent it
  notes      String?  // Additional notes on the action taken
  response   String?  // Builder's response if applicable
  respondedAt DateTime?

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([actionType])
  @@index([sentAt])
  @@index([channel])
  @@index([respondedAt])
}

// ─── OUTREACH AUTOMATION ────────────────────────────────────────────
// NOTE: Outreach tables (OutreachSequence, OutreachStep, OutreachEnrollment,
// OutreachEnrollmentStep, OutreachTemplate) are created dynamically via
// CREATE TABLE IF NOT EXISTS in the outreach-engine API route.
// They use raw SQL ($queryRawUnsafe / $executeRawUnsafe) and are NOT
// managed by Prisma migrations to avoid schema drift issues.

// ─── NEW ENUMS FOR ADDITIONAL FEATURES ───────────────────────────────

enum CategoryType {
  CORE
  EXTENDED
  PREMIUM
}

enum BuilderRole {
  PRIMARY
  SECONDARY
  CONTRACTOR
}

enum LeadSource {
  REFERRAL
  INBOUND
  OUTBOUND
  TRADE_SHOW
  OTHER
}

// ─── NEW ACCOUNT MANAGEMENT MODELS ───────────────────────────────────

model AccountCategoryMargin {
  id           String       @id @default(cuid())
  builderId    String
  category     String
  categoryType CategoryType @default(CORE)
  targetMargin Float        @default(0.25)
  minMargin    Float        @default(0.15)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  Builder      Builder      @relation(fields: [builderId], references: [id], onDelete: Cascade)

  @@unique([builderId, category])
  @@index([builderId])
}

model AccountMarginTarget {
  id                  String   @id @default(cuid())
  builderId           String   @unique
  targetBlendedMargin Float    @default(0.30)
  notes               String?
  setById             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  Builder             Builder  @relation(fields: [builderId], references: [id], onDelete: Cascade)
}

model AccountReviewTrigger {
  id          String    @id @default(cuid())
  builderId   String
  triggerType String
  severity    String?   @default("MEDIUM")
  description String?
  isResolved  Boolean?  @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([builderId])
  @@index([isResolved])
}

model AccountTouchpoint {
  id           String    @id @default(cuid())
  builderId    String
  staffId      String?
  touchType    String
  channel      String?   @default("PHONE")
  subject      String?
  notes        String?
  outcome      String?
  followUpDate DateTime?
  createdAt    DateTime  @default(now())

  @@index([builderId])
  @@index([createdAt])
}

// ─── BUILDER APPLICATIONS (Self-registration flow) ──────────────────

model BuilderApplication {
  id              String @id @default(cuid())
  builderId       String?
  referenceNumber String @unique // "APP1A2B3C4D"
  companyName     String
  contactName     String
  contactEmail    String
  contactPhone    String?
  address         String?
  city            String?
  state           String?
  zip             String?
  businessLicense String?
  taxId           String?
  estimatedAnnualVolume String?
  referralSource  String?
  notes           String?

  status          String @default("PENDING_APPROVAL") // PENDING_APPROVAL, APPROVED, REJECTED

  // Review
  reviewedById    String?
  reviewedAt      DateTime?
  reviewNotes     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([contactEmail])
  @@index([builderId])
  @@index([createdAt])
}

// ─── VEHICLE GPS TRACKING ────────────────────────────────────────────

model VehicleLocation {
  id        String @id @default(cuid())
  crewId    String
  vehicleId String? // License plate or fleet ID

  // GPS position
  latitude  Float
  longitude Float
  heading   Float?   // Compass bearing 0-360
  speed     Float?   // MPH

  // Context
  status    String   @default("IDLE") // IDLE, EN_ROUTE, AT_STOP, RETURNING
  address   String?  // Reverse-geocoded address (optional)

  // Link to active delivery (if any)
  activeDeliveryId String?

  timestamp DateTime @default(now())

  @@index([crewId])
  @@index([vehicleId])
  @@index([timestamp])
  @@index([activeDeliveryId])
}

// ─── MATERIAL WATCH (Tracks items awaiting stock for orders) ────────

model MaterialWatch {
  id        String @id @default(cuid())
  orderId   String
  orderItemId String?
  productId String
  jobId     String?

  // What we're waiting for
  sku         String
  productName String
  qtyNeeded   Int
  qtyAvailable Int @default(0)

  // Status
  status    String @default("AWAITING") // AWAITING, PARTIAL, ARRIVED, CANCELLED

  // Notification tracking
  notifiedSalesRep Boolean @default(false)
  notifiedOps      Boolean @default(false)
  arrivedAt        DateTime?

  // Who to notify
  salesRepId String?
  createdById String?

  // PO link (which PO is bringing this material)
  purchaseOrderId String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([status])
  @@index([purchaseOrderId])
  @@index([salesRepId])
  @@index([jobId])
}

// ─── BACKORDER TRACKER (Partial shipments + follow-up delivery) ─────

model BackorderItem {
  id        String @id @default(cuid())
  orderId   String
  orderItemId String?
  deliveryId  String?  // Original delivery that went out partial
  productId String

  // Item details
  sku         String
  productName String
  qtyOrdered  Int
  qtyShipped  Int    @default(0)
  qtyBackordered Int @default(0)

  // Tracking
  status    String @default("BACKORDERED") // BACKORDERED, MATERIAL_ARRIVED, SCHEDULED, DELIVERED, CANCELLED

  // Follow-up delivery
  followUpDeliveryId String?  // New delivery created when material arrives
  scheduledDeliveryDate DateTime?

  // Material arrival
  materialArrivedAt DateTime?
  purchaseOrderId   String?

  // Builder visibility
  builderNotified Boolean @default(false)
  builderNotifiedAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([deliveryId])
  @@index([productId])
  @@index([status])
  @@index([purchaseOrderId])
  @@index([followUpDeliveryId])
}

model AgentConfig {
  id          String   @id @default(cuid())
  agentRole   String
  configKey   String
  configValue Json
  description String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([agentRole, configKey])
  @@index([agentRole])
}
