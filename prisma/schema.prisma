  BACKORDER_UPDATE // Backorder status change
  OUTREACH_REVIEW // Outreach step ready for review
  SYSTEM
}

// ─── MESSAGING (Internal staff communication) ───────────────────

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Staff sender (DB NOT NULL — drift reconciled 2026-04-22).
  // For builder-originated messages, service layer stamps senderId with the
  // on-call staff; builderSenderId identifies the actual builder author.
  senderId String
  sender   Staff  @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Restrict)

  // Builder sender (null if staff sent the message)
  builderSenderId String?
  builderSender   Builder? @relation("BuilderMessagesSent", fields: [builderSenderId], references: [id], onDelete: Restrict)

  senderType String @default("STAFF") // "STAFF" or "BUILDER"

  body          String
  readBy        String[] // Array of staff IDs who read it
  readByBuilder Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([builderSenderId])
  @@index([createdAt])
}

model Conversation {
  id              String           @id @default(cuid())
  type            ConversationType
  name            String? // For groups/channels
  departmentScope String? // Department name for department channels (e.g. "EXECUTIVE", "SALES")

  // DB NOT NULL — drift reconciled 2026-04-22. Every conversation has a creator;
  // for builder-support threads the on-call staff is stamped server-side.
  createdById String
  createdBy   Staff  @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: Restrict)

  // Builder support thread link (BUILDER_SUPPORT type only)
  builderId String?
  builder   Builder? @relation("BuilderConversations", fields: [builderId], references: [id], onDelete: Cascade)
  subject   String? // Thread subject for builder support

  participants ConversationParticipant[]
  messages     Message[]

  lastMessageAt      DateTime?
  lastMessagePreview String? // Short preview of last message

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([createdById])
  @@index([lastMessageAt])
  @@index([builderId])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  staffId        String
  staff          Staff        @relation("ConversationParticipants", fields: [staffId], references: [id], onDelete: Cascade)

  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  @@unique([conversationId, staffId])
  @@index([conversationId])
  @@index([staffId])
}

model Notification {
  id      String @id @default(cuid())
  staffId String
  staff   Staff  @relation("StaffNotifications", fields: [staffId], references: [id], onDelete: Cascade)

  type  NotificationType
  title String
  body  String
  link  String? // URL to navigate to
  read  Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([staffId])
  @@index([read])
  @@index([type])
  @@index([createdAt])
}

// ─── SALES PIPELINE & DEALS ─────────────────────────────────────────
// Full CRM pipeline for sales reps to track prospects through to close

model Deal {
  id         String @id @default(cuid())
  dealNumber String @unique // e.g., "DEAL-2026-0042"

  // Prospect / Builder info
  companyName  String
  contactName  String
  contactEmail String?
  contactPhone String?
  address      String?
  city         String?
  state        String?
  zip          String?

  // Pipeline
  stage       DealStage  @default(PROSPECT)
  probability Int        @default(10) // 0-100% win probability
  dealValue   Float      @default(0) // Estimated annual revenue
  source      DealSource @default(OUTBOUND)

  // Dates
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  lostDate          DateTime?
  lostReason        String?

  // Assignment
  ownerId String
  owner   Staff  @relation("DealOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  // Link to builder once converted
  builderId String?

  // Notes
  description String? // What they build, territory, volume, etc.
  notes       String?

  // Relationships
  activities       DealActivity[]
  contracts        Contract[]
  documentRequests DocumentRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([stage])
  @@index([builderId])
  @@index([expectedCloseDate])
  @@index([dealNumber])
  @@index([source])
  @@index([probability])
}

enum DealStage {
  PROSPECT // Initial lead — not yet contacted
  DISCOVERY // First contact made, gathering info
  WALKTHROUGH // Site walkthrough or showroom visit scheduled/done
  BID_SUBMITTED // Formal bid/proposal sent
  BID_REVIEW // Builder reviewing bid
  NEGOTIATION // Active negotiation on terms/pricing
  WON // Deal closed — moving to onboarding
  LOST // Deal lost to competitor or abandoned
  ONBOARDED // Builder fully set up on platform
}

enum DealSource {
  OUTBOUND // Rep cold outreach
  REFERRAL // Referred by existing builder
  INBOUND // Builder inquired via website/phone
  TRADE_SHOW // Met at trade show / event
  REACTIVATION // Previous customer re-engagement
}

// ─── DEAL ACTIVITY LOG ──────────────────────────────────────────────

model DealActivity {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  staffId String
  staff   Staff  @relation("DealActivities", fields: [staffId], references: [id], onDelete: Restrict)

  type    DealActivityType
  subject String
  notes   String?
  outcome String?

  // Follow-up scheduling
  followUpDate DateTime?
  followUpDone Boolean   @default(false)

  createdAt DateTime @default(now())

  @@index([dealId])
  @@index([staffId])
  @@index([type])
  @@index([followUpDate])
  @@index([followUpDone])
  @@index([createdAt])
}

enum DealActivityType {
  CALL
  EMAIL
  MEETING
  SITE_VISIT
  TEXT
  NOTE
  STAGE_CHANGE
  BID_SENT
  BID_REVISED
  CONTRACT_SENT
  CONTRACT_SIGNED
  DOCUMENT_REQUESTED
  DOCUMENT_RECEIVED
  FOLLOW_UP
}

// ─── CONTRACTS ──────────────────────────────────────────────────────

model Contract {
  id             String @id @default(cuid())
  contractNumber String @unique // e.g., "CTR-2026-0015"

  dealId    String?
  deal      Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)
  builderId String?

  // Contract details
  title  String
  type   ContractType   @default(SUPPLY_AGREEMENT)
  status ContractStatus @default(DRAFT)

  // Financial terms
  paymentTerm     PaymentTerm @default(NET_30)
  creditLimit     Float?
  estimatedAnnual Float? // Estimated annual volume
  discountPercent Float       @default(0) // Negotiated discount

  // Content
  terms          String? // Contract terms text
  specialClauses String? // Special conditions

  // Dates
  startDate   DateTime?
  endDate     DateTime?
  sentDate    DateTime?
  signedDate  DateTime?
  expiresDate DateTime?

  // People
  createdById String?
  createdBy   Staff?  @relation("ContractCreator", fields: [createdById], references: [id], onDelete: SetNull)

  // File
  documentUrl  String? // Uploaded signed contract PDF
  templateUsed String? // Which template was used

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Drifted columns promoted from live DB (2026-04-22)
  organizationId String // FK -> BuilderOrganization.id (NOT NULL in DB)
  description    String?
  rebatePercent  Float     @default(0)
  effectiveDate  DateTime?
  expirationDate DateTime?
  signedAt       DateTime?
  signedBy       String?
  autoRenew      Boolean   @default(false)
  notes          String?
  divisionId     String? // FK -> Division.id

  @@index([dealId])
  @@index([builderId])
  @@index([status])
  @@index([createdById])
  @@index([contractNumber])
  @@index([signedDate])
}

enum ContractType {
  SUPPLY_AGREEMENT // Standard supply agreement
  MASTER_SERVICE // Master service agreement
  PRICING_AGREEMENT // Custom pricing terms
  NDA // Non-disclosure agreement
  CREDIT_APPLICATION // Credit application
}

enum ContractStatus {
  DRAFT // Being prepared
  INTERNAL_REVIEW // Internal review before sending
  SENT // Sent to builder for review
  BUILDER_REVIEW // Builder reviewing
  REVISION_REQUESTED // Builder requested changes
  SIGNED // Both parties signed
  ACTIVE // Currently active
  EXPIRED // Past end date
  TERMINATED // Early termination
}

// ─── DOCUMENT REQUESTS (COI, W-9, Credit Apps, etc.) ────────────────

model DocumentRequest {
  id String @id @default(cuid())

  dealId    String?
  deal      Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)
  builderId String?

  // What's needed
  documentType DocumentType
  title        String
  description  String?

  // Status tracking
  status DocumentRequestStatus @default(PENDING)

  // Who's involved
  requestedById String
  requestedBy   Staff  @relation("DocRequester", fields: [requestedById], references: [id], onDelete: Restrict)

  // File tracking
  fileUrl  String? // Uploaded document URL
  fileName String?

  // Dates
  dueDate      DateTime?
  receivedDate DateTime?
  expiresDate  DateTime? // For COIs and other expiring docs

  // Follow-up
  reminderSent Boolean   @default(false)
  reminderDate DateTime?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([builderId])
  @@index([status])
  @@index([documentType])
  @@index([requestedById])
  @@index([dueDate])
  @@index([expiresDate])
  @@index([reminderSent])
}

enum DocumentType {
  COI // Certificate of Insurance
  W9 // W-9 Tax Form
  CREDIT_APPLICATION // Credit application
  BUSINESS_LICENSE // Business license
  TAX_EXEMPT_CERT // Tax exemption certificate
  BOND // Surety bond
  REFERENCES // Trade/credit references
  FINANCIAL_STATEMENT // Financial statement
  OTHER // Custom document
}

enum DocumentRequestStatus {
  PENDING // Requested, not yet sent to builder
  SENT // Request sent to builder
  RECEIVED // Document received
  APPROVED // Document reviewed and approved
  REJECTED // Document rejected (needs resubmission)
  EXPIRED // Document has expired
}

