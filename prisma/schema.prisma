generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── BUILDER ACCOUNTS ────────────────────────────────────────────────

model Builder {
  id            String  @id @default(cuid())
  companyName   String
  contactName   String
  email         String  @unique
  passwordHash  String
  phone         String?
  address       String?
  city          String?
  state         String?
  zip           String?
  licenseNumber String?

  // Two-tier builder classification
  // PRODUCTION = national/regional (Toll, DR Horton) — has communities underneath
  // CUSTOM     = custom home builders — all features centered on builder profile
  builderType  BuilderType @default(CUSTOM)
  territory    String? // Geographic territory / market
  annualVolume Int? // Estimated annual door units
  website      String?

  // Payment & pricing
  paymentTerm    PaymentTerm @default(NET_15)
  creditLimit    Float?
  accountBalance Float       @default(0)
  taxExempt      Boolean     @default(false)
  taxId          String?

  // Status
  status        AccountStatus @default(PENDING)
  emailVerified Boolean       @default(false)
  verifyToken   String?

  // Password reset
  resetToken       String?
  resetTokenExpiry DateTime?

  // Drifted columns promoted from live DB (2026-04-22)
  organizationId        String?
  role                  BuilderRole @default(PRIMARY)
  source                LeadSource?
  sourceDetail          String?
  approvalStatus        String?     @default("ACTIVE")
  qbListId              String?
  qbSyncedAt            DateTime?
  segmentTag            String?     @default("STANDARD")
  lifetimeValue         Float?      @default(0)
  churnRisk             String?     @default("LOW")
  lastAnalyzedAt        DateTime?
  divisionId            String?
  pricingTier           String?     @default("STANDARD")
  notifyEmail           Boolean?    @default(true)
  notifySms             Boolean?    @default(false)
  notifyDeliveryUpdates Boolean?    @default(true)
  notifyInvoiceReady    Boolean?    @default(true)
  notifyPaymentReceived Boolean?    @default(true)

  // Auto-invoice on delivery — when true, onOrderDelivered cascade creates a
  // DRAFT Invoice automatically. Set false for COD/prepay builders who invoice
  // manually.
  autoInvoiceOnDelivery Boolean @default(true)

  // Relationships
  projects          Project[]
  orders            Order[]
  templates         OrderTemplate[]
  customPricing     BuilderPricing[]
  homeowners        HomeownerAccess[]
  btProjectMappings BTProjectMapping[]
  referralsSent     BuilderReferral[]  @relation("ReferrerReferrals")
  referralsReceived BuilderReferral[]  @relation("ReferredBuilder")

  // Account margin & review
  categoryMargins AccountCategoryMargin[]
  marginTarget    AccountMarginTarget?

  // Community structure (production builders)
  communities Community[]
  contacts    BuilderContact[]

  // Job phase configuration
  phaseConfigs BuilderPhaseConfig[]

  // Unified messaging
  chatConversations Conversation[] @relation("BuilderConversations")
  chatMessagesSent  Message[]      @relation("BuilderMessagesSent")

  // Hyphen portal docs (plans, redlines, COs, schedules) — matched to builder
  hyphenDocuments HyphenDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([builderType])
}

enum BuilderType {
  PRODUCTION // National/regional builder with communities (Toll, DR Horton, Lennar)
  CUSTOM // Custom home builder — no community structure
}

enum PaymentTerm {
  PAY_AT_ORDER // 3% discount
  PAY_ON_DELIVERY // Standard price
  NET_15 // 1% premium
  NET_30 // 2.5% premium
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CLOSED
}

// ─── BUILDER COMMUNITIES (Two-Tier Architecture) ────────────────────────
// Production builders (Toll, DR Horton) have Communities underneath.
// Each Community has its own contacts, tasks, comm logs, sales orders,
// performance metrics, blueprints, and pricing — a full picture per community.
// Custom builders skip this layer; everything hangs off the Builder directly.

model Community {
  id        String  @id @default(cuid())
  builderId String
  builder   Builder @relation(fields: [builderId], references: [id], onDelete: Cascade)

  name    String // "Canyon Ridge Estates", "Sunset Mesa Phase 2"
  code    String? // Short code: "CRE", "SMP2"
  address String?
  city    String?
  state   String?
  zip     String?
  county  String?

  // Scope
  totalLots  Int             @default(0)
  activeLots Int             @default(0)
  phase      String? // "Phase 1", "Phase 2A"
  status     CommunityStatus @default(ACTIVE)

  // Division (some builders organize by division → community)
  division String? // "Dallas Division", "Houston Metro"

  // Performance
  avgOrderValue Float? // Rolling avg order $
  totalRevenue  Float? @default(0)
  totalOrders   Int?   @default(0)

  // Notes
  notes String?

  // Bolt integration
  boltId String? // Cross-ref to ECI Bolt community

  // Relationships
  contacts   BuilderContact[]
  floorPlans CommunityFloorPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([builderId, name])
  @@index([builderId])
  @@index([status])
  @@index([city, state])
  @@index([boltId])
}

enum CommunityStatus {
  PLANNING // Pre-development
  ACTIVE // Lots being built / orders flowing
  WINDING_DOWN // Last lots being completed
  CLOSED // All lots complete, no more orders
}

// ─── BUILDER CONTACTS (people at the builder org) ───────────────────────
// A contact can be org-level (custom builders) or community-level (production)

model BuilderContact {
  id        String  @id @default(cuid())
  builderId String
  builder   Builder @relation(fields: [builderId], references: [id], onDelete: Cascade)

  // Optional community link — if set, this contact is community-specific
  communityId String?
  community   Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)

  firstName String
  lastName  String
  email     String?
  phone     String?
  mobile    String?
  title     String? // "Purchasing Manager", "Super", "Division VP"
  role      ContactRole @default(OTHER)

  isPrimary       Boolean @default(false) // Primary contact for this builder or community
  receivesPO      Boolean @default(false) // Gets PO/order notifications
  receivesInvoice Boolean @default(false) // Gets invoice copies

  notes  String?
  active Boolean @default(true)

  // Builder Portal — per-contact permission tier (separate from `role`
  // which is job title). Computed default mapping when null:
  //   OWNER / DIVISION_VP            → EXECUTIVE
  //   everything else                → PM
  // (See BUILDER-PORTAL-SPEC.md §0.1.) Migration:
  //   prisma/migrations/20260430_add_portal_role/migration.sql
  portalRole PortalRole @default(PM)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([builderId])
  @@index([communityId])
  @@index([email])
  @@index([role])
}

enum ContactRole {
  OWNER // Builder company owner
  DIVISION_VP // Division VP (production builders)
  PURCHASING // Purchasing / procurement
  SUPERINTENDENT // Field superintendent
  PROJECT_MANAGER // PM on the builder side
  ESTIMATOR // Builder's estimator
  ACCOUNTS_PAYABLE // AP contact
  OTHER
}

// Builder Portal permission tier. Separate from ContactRole (job title).
// PM       — see own jobs, place quotes, view orders.
// EXECUTIVE — additional analytics + spend visibility across communities.
// ADMIN    — full builder-side admin (manage contacts, invoices, etc.).
enum PortalRole {
  PM
  EXECUTIVE
  ADMIN
}

// ─── COMMUNITY FLOOR PLANS ──────────────────────────────────────────────
// Production builders have standard floor plans per community

model CommunityFloorPlan {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  name       String // "The Aspen", "Plan 2450"
  planNumber String? // Builder's plan number
  sqFootage  Int?
  bedrooms   Int?
  bathrooms  Float? // 2.5 etc
  stories    Int?    @default(1)
  garageType String? // "2-car attached", "3-car"

  // Door package
  interiorDoorCount Int?
  exteriorDoorCount Int?
  basePackagePrice  Float? // Standard door package price

  // Takeoff reference
  blueprintUrl String? // Link to stored blueprint
  takeoffNotes String?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([communityId, name])
  @@index([communityId])
}

// ─── COMMUNITY NOTES ────────────────────────────────────────────────────
// Linked notes for community-level context (delivery preferences, site rules, etc.)

model CommunityNote {
  id          String @id @default(cuid())
  communityId String

  authorId String // Staff who wrote it
  category String  @default("GENERAL") // GENERAL, DELIVERY, SITE_ACCESS, QUALITY, PRICING
  content  String
  pinned   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([communityId])
  @@index([category])
}

// ─── BUILDER REFERRALS ──────────────────────────────────────────────────

model BuilderReferral {
  id         String  @id @default(cuid())
  referrerId String
  referrer   Builder @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)

  // Referred builder info
  referredCompany String
  referredContact String
  referredEmail   String
  referredPhone   String
  referralCode    String  @unique // ABEL-{lastName}-{random4}
  notes           String?

  // Status tracking
  status            ReferralStatus @default(PENDING)
  referredBuilderId String?
  referredBuilder   Builder?       @relation("ReferredBuilder", fields: [referredBuilderId], references: [id], onDelete: SetNull)

  // Credits
  creditAmount     Float     @default(250)
  referrerCredited Boolean   @default(false)
  referreeCredited Boolean   @default(false)
  creditedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([referredEmail]) // 1 active referral per email address
  @@index([referrerId])
  @@index([status])
  @@index([referredBuilderId])
}

enum ReferralStatus {
  PENDING // Referral submitted, awaiting contact
  CONTACTED // Referred company has been contacted
  SIGNED_UP // Referred builder created an account
  FIRST_ORDER // Referred builder placed first order
  CREDITED // Both referrer and referee credited
}

// ─── PROJECTS & BLUEPRINTS ───────────────────────────────────────────

model Project {
  id        String  @id @default(cuid())
  builderId String
  builder   Builder @relation(fields: [builderId], references: [id], onDelete: Restrict)

  name        String
  jobAddress  String?
  city        String?
  state       String?
  lotNumber   String?
  subdivision String?
  planName    String?
  sqFootage   Int?

  // Geo — optional, filled by geocoding jobAddress. Enables route optimization
  // and delivery map pins without re-geocoding on every pageview.
  latitude  Float?
  longitude Float?

  status ProjectStatus @default(DRAFT)

  // Relationships
  blueprints Blueprint[]
  takeoffs   Takeoff[]
  quotes     Quote[]
  homeowners HomeownerAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([builderId])
  @@index([status])
}

enum ProjectStatus {
  DRAFT
  BLUEPRINT_UPLOADED
  TAKEOFF_PENDING
  TAKEOFF_COMPLETE
  QUOTE_GENERATED
  QUOTE_APPROVED
  ORDERED
  IN_PROGRESS
  DELIVERED
  COMPLETE
}

model Blueprint {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fileName  String
  fileUrl   String
  fileSize  Int
  fileType  String // pdf, png, jpg, dwg
  pageCount Int?

  // AI processing
  processedAt      DateTime?
  processingStatus ProcessingStatus @default(PENDING)

  takeoffs Takeoff[]

  createdAt DateTime @default(now())

  @@index([projectId])
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

// ─── AI TAKEOFF ──────────────────────────────────────────────────────

model Takeoff {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Nullable: a takeoff can originate from a raw inquiry (no uploaded blueprint
  // yet) — blueprint-less takeoff entries back the /ops/takeoff-inquiries flow.
  blueprintId String?
  blueprint   Blueprint? @relation(fields: [blueprintId], references: [id], onDelete: Cascade)

  status     TakeoffStatus @default(PROCESSING)
  confidence Float? // 0-1 overall confidence score

  // AI results
  rawResult  Json? // Full AI response
  reviewedBy String? // Admin who reviewed
  reviewedAt DateTime?

  items TakeoffItem[]
  quote Quote?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([blueprintId])
  @@index([status])
}

enum TakeoffStatus {
  PROCESSING
  NEEDS_REVIEW
  APPROVED
  REJECTED
}

model TakeoffItem {
  id        String  @id @default(cuid())
  takeoffId String
  takeoff   Takeoff @relation(fields: [takeoffId], references: [id], onDelete: Cascade)

  // What was detected
  category    String // Interior Door, Exterior Door, Trim, Hardware, etc.
  description String // "2068 2-Panel Shaker Hollow Core LH"
  location    String? // "Master Bedroom", "Hallway", etc.
  quantity    Int

  // Matched product
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  // AI confidence
  confidence Float? // 0-1 per-item confidence
  aiNotes    String? // AI reasoning

  // Human overrides
  overridden   Boolean @default(false)
  originalDesc String? // What AI originally detected

  createdAt DateTime @default(now())

  @@index([takeoffId])
  @@index([productId])
  @@index([category])
}

// ─── QUOTES ──────────────────────────────────────────────────────────

model Quote {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  takeoffId String  @unique
  takeoff   Takeoff @relation(fields: [takeoffId], references: [id], onDelete: Cascade)

  quoteNumber String @unique // ABL-2026-0001
  version     Int    @default(1)

  // Pricing
  subtotal       Float
  taxRate        Float @default(0)
  taxAmount      Float @default(0)
  termAdjustment Float @default(0) // Payment term premium/discount
  total          Float

  // Status
  status     QuoteStatus @default(DRAFT)
  validUntil DateTime?
  approvedAt DateTime?
  approvedBy String?

  items QuoteItem[]
  order Order?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Drifted columns promoted from live DB (2026-04-22)
  signatureData     String?
  rejectedAt        DateTime?
  rejectionReason   String?
  changeNotes       String?
  aiOptimized       Boolean?  @default(false)
  originalTotal     Float?
  marginPercent     Float?
  aiRecommendations Json?
  floorPlanId       String?
  notes             String?

  @@index([projectId])
  @@index([quoteNumber])
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  ORDERED
}

model QuoteItem {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  productId String? // Nullable for custom line items (delivery fees, misc charges, etc.)
  product   Product? @relation(fields: [productId], references: [id], onDelete: Restrict)

  description String
  quantity    Int
  unitPrice   Float
  lineTotal   Float

  // Upgrade tracking
  isUpgrade     Boolean @default(false)
  baseProductId String? // What it replaced
  upgradeAdder  Float? // Additional cost over base

  // Room/location
  location String?

  sortOrder Int @default(0)

  @@index([quoteId])
  @@index([productId])
}

// ─── ORDERS ──────────────────────────────────────────────────────────

model Order {
  id        String  @id @default(cuid())
  builderId String
  builder   Builder @relation(fields: [builderId], references: [id], onDelete: Restrict)
  quoteId   String? @unique
  quote     Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  orderNumber String  @unique // ORD-2026-0001
  poNumber    String? // Builder's PO number

  // Pricing
  subtotal     Float
  taxAmount    Float @default(0)
  shippingCost Float @default(0)
  total        Float

  // Payment
  paymentTerm   PaymentTerm
  paymentStatus PaymentStatus @default(PENDING)
  paidAt        DateTime?
  dueDate       DateTime?

  // Fulfillment
  status        OrderStatus @default(RECEIVED)
  deliveryDate  DateTime?
  deliveryNotes String?

  // Business order date (distinct from row createdAt) — driven by InFlow OrderDate
  orderDate  DateTime?
  isForecast Boolean   @default(false)

  // InFlow sync
  inflowOrderId    String? @unique
  inflowCustomerId String?

  items OrderItem[]
  jobs  Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([builderId])
  @@index([orderNumber])
  @@index([status])
  @@index([orderDate])
  @@index([isForecast])
}

enum OrderStatus {
  RECEIVED
  CONFIRMED
  IN_PRODUCTION
  AWAITING_MATERIAL // Some items not in stock — watching for arrival
  READY_TO_SHIP
  PARTIAL_SHIPPED // Shipped with missing items on backorder
  SHIPPED
  DELIVERED
  COMPLETE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  INVOICED
  PAID
  OVERDUE
  REFUNDED
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  description String
  quantity    Int
  unitPrice   Float
  lineTotal   Float

  @@index([orderId])
  @@index([productId])
}

// ─── ORDER TEMPLATES ─────────────────────────────────────────────────

model OrderTemplate {
  id        String  @id @default(cuid())
  builderId String
  builder   Builder @relation(fields: [builderId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  sourceOrderId String? // Original order this was created from

  items OrderTemplateItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([builderId])
  @@index([sourceOrderId])
}

model OrderTemplateItem {
  id         String        @id @default(cuid())
  templateId String
  template   OrderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity Int
  notes    String?

  createdAt DateTime @default(now())

  @@index([templateId])
  @@index([productId])
}

// ─── PRODUCT CATALOG ─────────────────────────────────────────────────

model Product {
  id          String  @id @default(cuid())
  sku         String  @unique
  name        String
  displayName String? // Customer-facing product name
  description String?

  // Classification
  category    String // Interior Doors, Exterior Doors, Trim, Hardware
  subcategory String? // Pre-Hung, Slab, Bifold, etc.
  productType String  @default("PHYSICAL") // PHYSICAL | LABOR | SERVICE | OVERHEAD — gates Smart Reorder / MRP suggestions

  // Pricing
  cost         Float // Abel's cost
  basePrice    Float // Standard retail/builder price
  minMargin    Float  @default(0.25) // 25% floor
  laborCost    Float? @default(0) // Labor cost component (per unit)
  overheadCost Float? @default(0) // Overhead allocation (per unit)

  // Attributes (parsed from name)
  doorSize       String? // "2068", "2868"
  handing        String? // LH, RH, LHIS, RHIS
  coreType       String? // Hollow, Solid
  panelStyle     String? // 2-Panel, 6-Panel, Shaker, Flat
  jambSize       String? // 4-9/16, 6-9/16
  casingCode     String? // A-Col, C-322
  hardwareFinish String? // SN, BLK, ORB
  material       String? // Pine, MDF, Primed
  fireRating     String? // 20min, 45min, 90min

  // Images
  imageUrl     String? // Primary product image URL
  thumbnailUrl String? // Smaller thumbnail for lists/grids
  imageAlt     String? // Alt text for accessibility

  // Status
  active       Boolean @default(true)
  inStock      Boolean @default(true)
  leadTimeDays Int?

  // InFlow sync
  inflowId       String?
  inflowCategory String?
  lastSyncedAt   DateTime?

  // Catalog classification / sourcing (multi-location, supplier catalog)
  locationId  String? @default("loc_abel_dfw") // FK-like ref to Location
  categoryId  String? @default("cat_doors") // FK-like ref to ProductCategory
  supplierId  String? // FK-like ref to primary Supplier
  supplierSku String? // Supplier's own SKU for this product
  weight      Float? // Unit weight (lbs)
  dimensions  Json?   @default("{}") // { length, width, height, unit }
  minOrderQty Int?    @default(1) // Minimum order quantity

  // Relationships
  takeoffItems  TakeoffItem[]
  quoteItems    QuoteItem[]
  orderItems    OrderItem[]
  templateItems OrderTemplateItem[]
  bomParent     BomEntry[]          @relation("BomParent")
  bomComponent  BomEntry[]          @relation("BomComponent")
  builderPrices BuilderPricing[]
  upgradeFrom   UpgradePath[]       @relation("UpgradeFrom")
  upgradeTo     UpgradePath[]       @relation("UpgradeTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sku])
  @@index([category])
  @@index([active])
}

model BomEntry {
  id          String  @id @default(cuid())
  parentId    String
  parent      Product @relation("BomParent", fields: [parentId], references: [id], onDelete: Cascade)
  componentId String
  component   Product @relation("BomComponent", fields: [componentId], references: [id], onDelete: Cascade)

  quantity      Float   @default(1)
  componentType String? // Slab, Jamb, Casing, Hinge, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([componentId])
}

model BuilderPricing {
  id        String  @id @default(cuid())
  builderId String
  builder   Builder @relation(fields: [builderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  customPrice Float
  margin      Float? // Calculated margin at this price

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([builderId, productId])
  @@index([builderId])
  @@index([productId])
}

model UpgradePath {
  id            String  @id @default(cuid())
  fromProductId String
  fromProduct   Product @relation("UpgradeFrom", fields: [fromProductId], references: [id], onDelete: Cascade)
  toProductId   String
  toProduct     Product @relation("UpgradeTo", fields: [toProductId], references: [id], onDelete: Cascade)

  upgradeType String // door_style, hardware, core, finish
  costDelta   Float // Difference in cost
  priceDelta  Float // Suggested price adder
  description String? // "Upgrade from Hollow Core to Solid Core"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fromProductId, toProductId])
  @@index([fromProductId])
  @@index([toProductId])
}

// ─── HOMEOWNER PORTAL ────────────────────────────────────────────────

model HomeownerAccess {
  id        String  @id @default(cuid())
  builderId String
  builder   Builder @relation(fields: [builderId], references: [id], onDelete: Cascade)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Homeowner info
  name        String
  email       String
  phone       String?
  accessToken String  @unique // URL token for portal access

  // Selection tracking
  selections HomeownerSelection[]

  // Status
  active      Boolean   @default(true)
  expiresAt   DateTime?
  lastVisitAt DateTime?

  createdAt DateTime @default(now())

  @@index([accessToken])
  @@index([projectId])
  @@index([builderId])
  @@index([email])
  @@index([active])
}

model HomeownerSelection {
  id                String          @id @default(cuid())
  homeownerAccessId String
  homeownerAccess   HomeownerAccess @relation(fields: [homeownerAccessId], references: [id], onDelete: Cascade)

  location          String // "Master Bedroom Door"
  baseProductId     String // The default/base product
  selectedProductId String // What the homeowner picked
  adderCost         Float // Cost difference to homeowner

  status      SelectionStatus @default(PENDING)
  confirmedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([homeownerAccessId])
  @@index([status])
}

enum SelectionStatus {
  PENDING
  CONFIRMED
  LOCKED
}

// ═══════════════════════════════════════════════════════════════════════
// PM / CRM / ERP MODULE
// Based on Abel SOP frameworks & Module 2 Systems Training
// ═══════════════════════════════════════════════════════════════════════

// ─── STAFF & ROLES ──────────────────────────────────────────────────

model Staff {
  id           String     @id @default(cuid())
  firstName    String
  lastName     String
  email        String     @unique
  passwordHash String
  phone        String?
  role         StaffRole // Primary role (backward compat)
  roles        String? // Comma-separated list of ALL roles (multi-role support): "ADMIN,MANAGER,PROJECT_MANAGER"
  department   Department
  title        String? // "Project Manager", "Manufacturing Lead", etc.
  avatar       String? // Profile image URL
  active       Boolean    @default(true)
  hireDate     DateTime?

  // Reporting hierarchy (self-referential)
  managerId     String?
  manager       Staff?  @relation("StaffManager", fields: [managerId], references: [id])
  directReports Staff[] @relation("StaffManager")

  // Compensation
  salary         Float? // Annual salary (null if hourly)
  payType        PayType? // SALARY or HOURLY
  employmentType EmploymentType? // FULL_TIME_EXEMPT, FULL_TIME_NON_EXEMPT, etc.
  employeeId     String? // Internal ID (AL-001, etc.)

  // Auth — password reset flow
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  // Auth — invite / onboarding flow
  inviteToken        String?   @unique
  inviteTokenExpiry  DateTime?
  passwordSetAt      DateTime?
  mustChangePassword Boolean   @default(false)

  // Onboarding — handbook acknowledgment
  handbookSignedAt DateTime?
  handbookVersion  String?

  // Location assignment (FK to Location)
  locationId String?

  // Portal access overrides (JSON format): { "/ops/jobs": true, "/ops/finance": false }
  // true = explicitly GRANT access (even if role doesn't have it)
  // false = explicitly DENY access (even if role has it)
  // missing = use role-based default
  portalOverrides Json? @default("{}")

  // Per-user Aegis preferences (density, feature flags, first-view trackers).
  // Shape: { density, featureFlags: { AEGIS_V2_DRAFTING_ROOM: boolean }, hasSeen: {...} }
  // Migration: prisma/migrations/pending_staff_preferences.sql (not yet applied).
  preferences Json?

  // Relationships
  assignedJobs         Job[]                     @relation("AssignedPM")
  activities           Activity[]
  tasks                Task[]                    @relation("TaskAssignee")
  tasksCreated         Task[]                    @relation("TaskCreator")
  crewMembership       CrewMember[]
  decisionNotes        DecisionNote[]
  purchaseOrders       PurchaseOrder[]           @relation("POCreator")
  poApprovals          PurchaseOrder[]           @relation("POApprover")
  invoicesCreated      Invoice[]
  qualityChecks        QualityCheck[]
  notifications        Notification[]            @relation("StaffNotifications")
  conversations        ConversationParticipant[] @relation("ConversationParticipants")
  messagesSent         Message[]                 @relation("MessagesSent")
  conversationsCreated Conversation[]            @relation("ConversationCreator")

  // Sales
  ownedDeals       Deal[]            @relation("DealOwner")
  dealActivities   DealActivity[]    @relation("DealActivities")
  contractsCreated Contract[]        @relation("ContractCreator")
  documentRequests DocumentRequest[] @relation("DocRequester")

  // Compensation
  hourlyRate Float?

  // Fully-loaded cost model (Phase 2 payroll seed)
  annualSalary      Float? // Annualized base comp (salary or hourly * 2080)
  burdenRate        Float? // Benefits + tax multiplier (e.g. 1.28)
  fullyLoadedHourly Float? // hourlyRate * burdenRate
  monthlyCost       Float? // annualSalary / 12 (or hourly equivalent)
  costCenter        String? // GL cost center / department bucket
  payrollTitle      String? // Title as it appears in QB/payroll
  payrollUpdatedAt  DateTime? @db.Timestamptz // Last payroll sync time (tz-aware)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([department])
  @@index([active])
  @@index([managerId])
}

model StaffPreferences {
  id               String   @id @default(cuid())
  staffId          String   @unique
  theme            String   @default("system") // "light" | "dark" | "system"
  accentColor      String   @default("#C6A24E")
  fontSize         String   @default("medium") // "small" | "medium" | "large"
  sidebarCollapsed Boolean  @default(false)
  compactMode      Boolean  @default(false)
  dashboardLayout  Json?    @default("{}")
  hiddenSections   Json?    @default("[]")
  pinnedSections   Json?    @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([staffId])
}

enum StaffRole {
  ADMIN // Full system access
  MANAGER // Department manager
  PROJECT_MANAGER // PM - runs accounts & jobs
  ESTIMATOR // Pricing & takeoff review
  SALES_REP // Account acquisition
  PURCHASING // Vendor & PO management
  WAREHOUSE_LEAD // Manufacturing floor lead
  WAREHOUSE_TECH // Door line worker
  DRIVER // Delivery crew
  INSTALLER // Field install crew
  QC_INSPECTOR // Quality control
  ACCOUNTING // AR/AP/Invoicing
  VIEWER // Read-only access
}

enum Department {
  EXECUTIVE
  SALES
  BUSINESS_DEVELOPMENT
  ESTIMATING
  PROJECT_MANAGEMENT
  OPERATIONS
  MANUFACTURING
  PRODUCTION
  WAREHOUSE
  LOGISTICS
  DELIVERY
  INSTALLATION
  ACCOUNTING
  PURCHASING
}

enum PayType {
  SALARY
  HOURLY
}

enum EmploymentType {
  FULL_TIME_EXEMPT
  FULL_TIME_NON_EXEMPT
  PART_TIME
  CONTRACT
}

// ─── JOBS (Operational unit — links Quote/Order to field work) ───────
// A "Job" is the ops-side representation of a project drop/delivery
// Maps to ECI Bolt's job concept with Lot-Block-Community identifiers

model Job {
  id          String  @id @default(cuid())
  jobNumber   String  @unique // e.g., "JOB-2026-0142"
  boltJobId   String? // Cross-ref to ECI Bolt
  inflowJobId String? // Cross-ref to InFlow

  // Builder & project link
  orderId   String?
  order     Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  projectId String?
  // Not adding direct Project relation to avoid circular deps; use orderId->quote->project

  // Job identifiers (from Module 2 — Lot-Block system)
  lotBlock       String? // "Lot 14 Block 3"
  community      String? // "Canyon Ridge" (denormalized for quick display)
  communityId    String? // FK to Community table (if production builder)
  builderName    String // Denormalized for quick display
  builderContact String?
  jobAddress     String?
  latitude       Float?
  longitude      Float?
  bwpPoNumber    String? // Builder's PO number

  // Hyphen (Brookfield PM portal) cross-refs
  hyphenJobId      String?
  hyphenScheduleId String?

  // Division & location (multi-site readiness)
  divisionId String?
  locationId String? @default("loc_abel_dfw")

  // Scope & Type
  scopeType ScopeType
  jobType   JobType? // Operational phase: T1, T2, FF, DR, HW, QC, etc.
  dropPlan  String? // "Single Drop", "Staged", "Multi-Drop"

  // Assignment
  assignedPMId String?
  assignedPM   Staff?  @relation("AssignedPM", fields: [assignedPMId], references: [id], onDelete: SetNull)
  installerId  String?
  trimVendorId String?
  bomVersion   Int?    @default(1)

  // Status tracking (from Module 2 T-72/T-48/T-24 workflow)
  status                JobStatus @default(CREATED)
  readinessCheck        Boolean   @default(false) // T-72 readiness confirmed
  materialsLocked       Boolean   @default(false) // T-48 materials locked
  loadConfirmed         Boolean   @default(false) // T-24 truck loaded
  qcRequired            Boolean?  @default(true)
  allMaterialsAllocated Boolean?  @default(false)
  pickListGenerated     Boolean?  @default(false)
  buildSheetNotes       String?
  scheduledDate         DateTime? // Target delivery/install date
  actualDate            DateTime?
  completedAt           DateTime?

  // Relationships
  decisionNotes     DecisionNote[]
  scheduleEntries   ScheduleEntry[]
  materialPicks     MaterialPick[]
  qualityChecks     QualityCheck[]
  deliveries        Delivery[]
  installations     Installation[]
  tasks             Task[]
  activities        Activity[]
  btProjectMappings BTProjectMapping[]
  phases            JobPhase[]
  hyphenDocuments   HyphenDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([assignedPMId])
  @@index([scheduledDate])
  @@index([builderName])
  @@index([community])
  @@index([communityId])
  @@index([orderId])
}

enum JobStatus {
  CREATED
  READINESS_CHECK // T-72: materials & specs being verified
  MATERIALS_LOCKED // T-48: materials confirmed in InFlow
  IN_PRODUCTION // Manufacturing/assembly
  STAGED // Warehouse staging complete
  LOADED // On truck
  IN_TRANSIT // Delivery en route
  DELIVERED // On site
  INSTALLING // Install crew working
  PUNCH_LIST // Fixes/touch-ups needed
  COMPLETE // All work done
  INVOICED // Invoice sent
  CLOSED // Payment received, job archived
}

// Job Type — operational phase/visit type (drives job numbering + calendar color coding)
// Job number format: "<address> <type_code>" e.g. "10567 Boxthorn T1"
enum JobType {
  TRIM_1 // T1 — first trim package
  TRIM_1_INSTALL // T1I — first trim install
  TRIM_2 // T2 — second trim (finish)
  TRIM_2_INSTALL // T2I — second trim install
  DOORS // DR — door delivery
  DOOR_INSTALL // DRI — door install
  HARDWARE // HW — hardware delivery
  HARDWARE_INSTALL // HWI — hardware install
  FINAL_FRONT // FF — final front (porch columns, exterior trim)
  FINAL_FRONT_INSTALL // FFI — final front install
  QC_WALK // QC — quality control walkthrough
  PUNCH // PL — punch list fixes
  WARRANTY // WR — warranty callback
  CUSTOM // CU — custom / other
}

enum ScopeType {
  DOORS_ONLY
  TRIM_ONLY
  DOORS_AND_TRIM
  HARDWARE_ONLY
  FULL_PACKAGE // Doors + trim + hardware + install
  CUSTOM
}

// ─── DECISION NOTES (from Module 2 — ECI Bolt SOPs) ────────────────
// Standardized communication log for each job with typed prefixes

model DecisionNote {
  id       String @id @default(cuid())
  jobId    String
  job      Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  authorId String
  author   Staff  @relation(fields: [authorId], references: [id], onDelete: Restrict)

  noteType DecisionNoteType
  subject  String // Brief summary
  body     String // Full note content (BLUF format)
  priority NotePriority     @default(NORMAL)

  // Linked artifacts
  attachmentUrl String?
  relatedTaskId String?

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([noteType])
  @@index([authorId])
  @@index([priority])
}

enum DecisionNoteType {
  READINESS // [READINESS] — T-72 check
  LOCK // [LOCK] — Materials locked
  ARRIVED // [ARRIVED] — Material arrived
  COMPLETE // [COMPLETE] — Job completed
  EXCEPTION // [EXCEPTION] — Issue found
  ESCALATION // [ESCALATION] — Needs manager attention
  APPROVAL // [APPROVAL] — Pricing/change approved
  CLOSEOUT // [CLOSEOUT] — Job closing notes
  GENERAL // General note
}

enum NotePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ─── ACTIVITIES (CRM interaction log) ───────────────────────────────

model Activity {
  id      String @id @default(cuid())
  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Restrict)

  // Polymorphic link — activity can relate to a builder, community, job, or combo
  builderId   String?
  communityId String? // Link to community for production builders
  jobId       String?
  job         Job?    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  activityType ActivityType
  subject      String
  notes        String?
  outcome      String? // "Left voicemail", "Agreed to NET_15", etc.

  // Scheduling
  scheduledAt  DateTime?
  completedAt  DateTime?
  durationMins Int?

  // Idempotency key for event-driven emission
  // (e.g. "commlog:<id>", "deal:<id>:stage:<stage>", "quote:<id>:sent")
  sourceKey String? @unique

  createdAt DateTime @default(now())

  @@index([builderId])
  @@index([communityId])
  @@index([jobId])
  @@index([staffId])
  @@index([activityType])
  @@index([scheduledAt])
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  SITE_VISIT
  TEXT_MESSAGE
  NOTE
  QUOTE_SENT
  QUOTE_FOLLOW_UP
  ISSUE_REPORTED
  ISSUE_RESOLVED
}

// ─── TASKS (PM action items & follow-ups) ───────────────────────────

model Task {
  id String @id @default(cuid())

  // Assignment
  assigneeId String
  assignee   Staff  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  creatorId  String
  creator    Staff  @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Restrict)

  // Context
  jobId       String?
  job         Job?    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  builderId   String?
  communityId String? // Link to community for production builders

  // Task details
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  category    TaskCategory @default(GENERAL)

  dueDate     DateTime?
  completedAt DateTime?

  // Idempotency key for event-driven emission
  // (e.g. "order:<id>:received", "invoice:<id>:overdue", "inspection:<id>:fail")
  sourceKey String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assigneeId])
  @@index([jobId])
  @@index([status])
  @@index([dueDate])
  @@index([creatorId])
  @@index([builderId])
  @@index([communityId])
  @@index([priority])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum TaskCategory {
  GENERAL
  READINESS_CHECK
  MATERIAL_VERIFICATION
  BUILDER_COMMUNICATION
  CREW_DISPATCH
  QUALITY_REVIEW
  INVOICE_FOLLOW_UP
  SCHEDULING
  EXCEPTION_RESOLUTION
}

// ─── SCHEDULING & DISPATCH ──────────────────────────────────────────

model ScheduleEntry {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  entryType     ScheduleType
  title         String
  scheduledDate DateTime
  scheduledTime String? // "8:00 AM", "Morning", "PM"

  // Assignment
  crewId String?
  crew   Crew?   @relation(fields: [crewId], references: [id], onDelete: SetNull)

  status ScheduleStatus @default(TENTATIVE)
  notes  String?

  // Actual timing
  startedAt   DateTime?
  completedAt DateTime?

  // Back-ref to the invoice line that triggered this entry (loose, nullable).
  invoiceItemId String?
  invoiceItem   InvoiceItem? @relation(fields: [invoiceItemId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduledDate])
  @@index([crewId])
  @@index([status])
  @@index([jobId])
  @@index([invoiceItemId])
}

enum ScheduleType {
  DELIVERY
  INSTALLATION
  PICKUP
  RETURN
  INSPECTION
  RESTOCKING
}

enum ScheduleStatus {
  TENTATIVE // Planned but not confirmed
  FIRM // Confirmed with crew & builder
  IN_PROGRESS
  COMPLETED
  RESCHEDULED
  CANCELLED
}

// ─── CREWS (Delivery & Install teams) ───────────────────────────────

model Crew {
  id       String   @id @default(cuid())
  name     String // "Delivery Team A", "Install Crew - Sean"
  crewType CrewType
  active   Boolean  @default(true)

  // Vehicle (for delivery crews)
  vehicleId    String?
  vehiclePlate String?

  members         CrewMember[]
  scheduleEntries ScheduleEntry[]
  deliveries      Delivery[]
  installations   Installation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

enum CrewType {
  DELIVERY
  INSTALLATION
  DELIVERY_AND_INSTALL
}

model CrewMember {
  id      String @id @default(cuid())
  crewId  String
  crew    Crew   @relation(fields: [crewId], references: [id], onDelete: Cascade)
  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  role    String @default("Member") // "Lead", "Member", "Driver"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([crewId, staffId])
  @@index([crewId])
  @@index([staffId])
}

// ─── DELIVERIES (from Delivery Crew SOP) ────────────────────────────

model Delivery {
  id     String  @id @default(cuid())
  jobId  String
  job    Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  crewId String?
  crew   Crew?   @relation(fields: [crewId], references: [id], onDelete: SetNull)

  // Route
  deliveryNumber String @unique // "DEL-2026-0089"
  routeOrder     Int    @default(0)
  address        String

  // Execution
  status      DeliveryStatus @default(SCHEDULED)
  departedAt  DateTime?
  arrivedAt   DateTime?
  completedAt DateTime?

  // Documentation (from SOP — photo requirements)
  loadPhotos String[] // URLs to load confirmation photos
  sitePhotos String[] // URLs to on-site drop photos
  signedBy   String? // Who signed for delivery

  // Issues
  damageNotes String?
  returnItems String? // Items refused or damaged

  notes String?

  // Tracking updates
  tracking DeliveryTracking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([status])
  @@index([crewId])
  @@index([deliveryNumber])
}

enum DeliveryStatus {
  SCHEDULED
  LOADING
  IN_TRANSIT
  ARRIVED
  UNLOADING
  COMPLETE
  PARTIAL_DELIVERY
  REFUSED
  RESCHEDULED
}

// ─── DELIVERY TRACKING (Real-time delivery status updates) ────────────

model DeliveryTracking {
  id         String   @id @default(cuid())
  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  status    String // PICKING, LOADED, DEPARTED, EN_ROUTE, NEARBY, ARRIVED, UNLOADING, COMPLETE
  location  String? // Current location/address
  notes     String? // Additional notes
  eta       DateTime? // Estimated time of arrival
  updatedBy String // Staff ID of who made the update

  timestamp DateTime @default(now())

  @@index([deliveryId])
  @@index([timestamp])
  @@index([status])
}

// ─── INSTALLATIONS (from PM SOP — field work tracking) ──────────────

model Installation {
  id     String  @id @default(cuid())
  jobId  String
  job    Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  crewId String?
  crew   Crew?   @relation(fields: [crewId], references: [id], onDelete: SetNull)

  installNumber String  @unique // "INS-2026-0063"
  scopeNotes    String? // What's being installed

  status        InstallationStatus @default(SCHEDULED)
  scheduledDate DateTime?
  startedAt     DateTime?
  completedAt   DateTime?

  // Quality
  passedQC   Boolean @default(false)
  punchItems String? // Punch list items if any

  // Documentation
  beforePhotos String[]
  afterPhotos  String[]

  notes String?

  // Back-ref to the invoice line that triggered this install (loose, nullable).
  invoiceItemId String?
  invoiceItem   InvoiceItem? @relation(fields: [invoiceItemId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([status])
  @@index([crewId])
  @@index([installNumber])
  @@index([invoiceItemId])
}

enum InstallationStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETE
  PUNCH_LIST
  REWORK
  CANCELLED
}

// ─── QUALITY CONTROL (from Manufacturing SOP) ───────────────────────

model QualityCheck {
  id          String  @id @default(cuid())
  jobId       String?
  job         Job?    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  inspectorId String
  inspector   Staff   @relation(fields: [inspectorId], references: [id], onDelete: Restrict)

  checkType   QCType
  result      QCResult
  notes       String?
  defectCodes String[] // Standard defect codes

  // Photos
  photos String[]

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([checkType])
  @@index([inspectorId])
  @@index([result])
}

enum QCType {
  PRE_PRODUCTION // Before assembly
  IN_PROCESS // During manufacturing
  FINAL_UNIT // After assembly, before staging
  PRE_DELIVERY // Load check
  POST_INSTALL // On-site quality
}

enum QCResult {
  PASS
  FAIL
  CONDITIONAL_PASS // Minor issues noted but acceptable
}

// ─── PURCHASING & INVENTORY ─────────────────────────────────────────

model Vendor {
  id            String  @id @default(cuid())
  name          String // "DW Distribution", "Boise Cascade"
  code          String  @unique // "DW", "BC", "MASO"
  contactName   String?
  email         String?
  phone         String?
  address       String?
  website       String?
  accountNumber String? // Abel's account # with this vendor

  // Performance
  avgLeadDays Int?
  onTimeRate  Float? // 0-1
  riskScore   Float? @default(0) // 0-1 vendor risk composite

  active Boolean @default(true)

  // Payment terms / pricing structure
  paymentTerms          String? // Free-text (e.g. "Net 30", "2/10 Net 30")
  paymentTermDays       Int?    @default(30) // Numeric net days
  earlyPayDiscount      Float?  @default(0) // Discount % for early pay
  earlyPayDays          Int?    @default(0) // Days for early-pay discount window
  minOrderValue         Float?  @default(0) // Minimum PO $ value
  bulkDiscountThreshold Float? // $ threshold for bulk discount
  bulkDiscountPercent   Float? // % discount above threshold

  // Credit exposure
  creditLimit Float?   @default(0) // Credit line granted
  creditUsed  Float?   @default(0) // Current outstanding AP balance
  creditHold  Boolean? @default(false) // If true, block new POs

  // Identifiers / misc
  taxId String?
  notes String?

  // InFlow sync
  inflowVendorId String? @unique

  purchaseOrders PurchaseOrder[]
  vendorProducts VendorProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([active])
  @@index([inflowVendorId])
}

// Maps products to their vendor/supplier catalog entries
model VendorProduct {
  id        String @id @default(cuid())
  vendorId  String
  vendor    Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  productId String
  // Not adding direct Product relation to keep migration clean

  vendorSku    String // Vendor's own SKU
  vendorName   String? // Vendor's product name
  vendorCost   Float? // What we pay the vendor
  minOrderQty  Int     @default(1)
  leadTimeDays Int?
  preferred    Boolean @default(false) // Is this the preferred vendor for this product?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendorId, productId])
  @@index([productId])
  @@index([vendorId])
  @@index([preferred])
}

// Trim/install subcontractor vendors (separate from material Vendor / Supplier).
// Used for labor pricing on install crews — DFW Door, Texas Innovation, etc.
model TrimVendor {
  id           String   @id @default(cuid())
  name         String // "DFW Door", "Texas Innovation"
  contactEmail String?
  contactPhone String?
  rates        Json     @default("{}") // { "interior_prehung": 45.00, "exterior": 85.00, ... }
  active       Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
}

model PurchaseOrder {
  id       String @id @default(cuid())
  poNumber String @unique // "PO-2026-0451"
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  createdById  String
  createdBy    Staff   @relation("POCreator", fields: [createdById], references: [id], onDelete: Restrict)
  approvedById String?
  approvedBy   Staff?  @relation("POApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  status       POStatus   @default(DRAFT)
  category     POCategory @default(GENERAL)
  subtotal     Float      @default(0)
  shippingCost Float      @default(0)
  total        Float      @default(0)

  // Dates
  orderedAt    DateTime?
  expectedDate DateTime? // Expected delivery from vendor
  receivedAt   DateTime?

  // Payment tracking (Finance FIX-10)
  paidAt        DateTime?
  paidMethod    String?
  paidReference String?
  paidAmount    Float?

  // Vendor confirmation (GAP-23)
  vendorConfirmedAt   DateTime?
  vendorConfirmedDate DateTime?
  vendorPONumber      String?

  notes String?

  // InFlow sync
  inflowId       String? @unique
  inflowVendorId String?

  // QuickBooks sync
  qbTxnId    String?
  qbSyncedAt DateTime?

  // AI auto-reorder metadata
  aiGenerated          Boolean? @default(false)
  recommendationId     String?
  consolidationGroupId String?
  projectedLeadDays    Int?
  actualLeadDays       Int?
  savingsVsLastOrder   Float?   @default(0)

  // Provenance — 'INFLOW' for real data, 'LEGACY_SEED' for pre-import bulk records
  source String?

  items PurchaseOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
  @@index([status])
  @@index([createdById])
