generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Builder {
  id                    String                  @id @default(cuid())
  companyName           String
  contactName           String
  email                 String                  @unique
  passwordHash          String
  phone                 String?
  address               String?
  city                  String?
  state                 String?
  zip                   String?
  licenseNumber         String?
  paymentTerm           PaymentTerm             @default(NET_15)
  creditLimit           Float?
  accountBalance        Float                   @default(0)
  taxExempt             Boolean                 @default(false)
  taxId                 String?
  status                AccountStatus           @default(PENDING)
  emailVerified         Boolean                 @default(false)
  verifyToken           String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  organizationId        String?
  role                  BuilderRole             @default(PRIMARY)
  source                LeadSource?
  sourceDetail          String?
  resetToken            String?
  resetTokenExpiry      DateTime?               @db.Timestamp(6)
  approvalStatus        String?                 @default("ACTIVE")
  qbListId              String?
  qbSyncedAt            DateTime?
  segmentTag            String?                 @default("STANDARD")
  lifetimeValue         Float?                  @default(0)
  churnRisk             String?                 @default("LOW")
  lastAnalyzedAt        DateTime?
  divisionId            String?
  pricingTier           String?                 @default("STANDARD")
  notifyEmail           Boolean?                @default(true)
  notifySms             Boolean?                @default(false)
  notifyDeliveryUpdates Boolean?                @default(true)
  notifyInvoiceReady    Boolean?                @default(true)
  notifyPaymentReceived Boolean?                @default(true)
  AccountCategoryMargin AccountCategoryMargin[]
  AccountMarginTarget   AccountMarginTarget?
  AgentConversation     AgentConversation[]
  AgentEmailLog         AgentEmailLog[]
  AgentSmsLog           AgentSmsLog[]
  btProjectMappings     BTProjectMapping[]
  Division              Division?               @relation(fields: [divisionId], references: [id])
  BuilderOrganization   BuilderOrganization?    @relation(fields: [organizationId], references: [id])
  BuilderBranding       BuilderBranding?
  BuilderCatalog        BuilderCatalog[]
  BuilderIntelligence   BuilderIntelligence?
  customPricing         BuilderPricing[]
  BuilderScheduleShare  BuilderScheduleShare[]
  CommunicationLog      CommunicationLog[]
  homeowners            HomeownerAccess[]
  LienRelease           LienRelease[]
  MessageReadReceipt    MessageReadReceipt[]
  orders                Order[]
  templates             OrderTemplate[]
  projects              Project[]
  ReorderSuggestion     ReorderSuggestion[]
  SavedCart             SavedCart[]
  ScheduleChangeRequest ScheduleChangeRequest[]
  SubcontractorPricing  SubcontractorPricing[]
  TradeReview           TradeReview[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([divisionId])
  @@index([organizationId])
  @@index([resetToken])
  @@index([pricingTier], map: "idx_builder_pricing_tier")
  @@index([status, companyName], map: "idx_builder_status_company")
}

model Project {
  id          String            @id @default(cuid())
  builderId   String
  name        String
  jobAddress  String?
  city        String?
  state       String?
  lotNumber   String?
  subdivision String?
  planName    String?
  sqFootage   Int?
  status      ProjectStatus     @default(DRAFT)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  blueprints  Blueprint[]
  FloorPlan   FloorPlan[]
  homeowners  HomeownerAccess[]
  builder     Builder           @relation(fields: [builderId], references: [id])
  quotes      Quote[]
  takeoffs    Takeoff[]

  @@index([builderId])
  @@index([status])
  @@index([createdAt])
}

model Blueprint {
  id               String           @id @default(cuid())
  projectId        String
  fileName         String
  fileUrl          String
  fileSize         Int
  fileType         String
  pageCount        Int?
  processedAt      DateTime?
  processingStatus ProcessingStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  takeoffs         Takeoff[]

  @@index([projectId])
  @@index([processingStatus])
}

model Takeoff {
  id          String        @id @default(cuid())
  projectId   String
  blueprintId String
  status      TakeoffStatus @default(PROCESSING)
  confidence  Float?
  rawResult   Json?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  floorPlanId String?
  quote       Quote?
  blueprint   Blueprint     @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  FloorPlan   FloorPlan?    @relation(fields: [floorPlanId], references: [id], onUpdate: NoAction)
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items       TakeoffItem[]

  @@index([projectId])
  @@index([blueprintId])
}

model TakeoffItem {
  id           String   @id @default(cuid())
  takeoffId    String
  category     String
  description  String
  location     String?
  quantity     Int
  productId    String?
  confidence   Float?
  aiNotes      String?
  overridden   Boolean  @default(false)
  originalDesc String?
  createdAt    DateTime @default(now())
  product      Product? @relation(fields: [productId], references: [id])
  takeoff      Takeoff  @relation(fields: [takeoffId], references: [id], onDelete: Cascade)

  @@index([takeoffId])
}

model Quote {
  id                String      @id @default(cuid())
  projectId         String
  takeoffId         String      @unique
  quoteNumber       String      @unique
  version           Int         @default(1)
  subtotal          Float
  taxRate           Float       @default(0)
  taxAmount         Float       @default(0)
  termAdjustment    Float       @default(0)
  total             Float
  status            QuoteStatus @default(DRAFT)
  validUntil        DateTime?
  approvedAt        DateTime?
  approvedBy        String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  signatureData     String?
  rejectedAt        DateTime?   @db.Timestamp(6)
  rejectionReason   String?
  changeNotes       String?
  aiOptimized       Boolean?    @default(false)
  originalTotal     Float?
  marginPercent     Float?
  aiRecommendations Json?
  floorPlanId       String?
  notes             String?
  order             Order?
  FloorPlan         FloorPlan?  @relation(fields: [floorPlanId], references: [id], onUpdate: NoAction)
  project           Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  takeoff           Takeoff     @relation(fields: [takeoffId], references: [id], onDelete: Cascade)
  items             QuoteItem[]

  @@index([projectId])
  @@index([quoteNumber])
  @@index([status])
  @@index([validUntil])
  @@index([projectId, status], map: "idx_quote_project_status")
  @@index([status, createdAt(sort: Desc)], map: "idx_quote_status_created")
}

model QuoteItem {
  id            String  @id @default(cuid())
  quoteId       String
  productId     String
  description   String
  quantity      Int
  unitPrice     Float
  lineTotal     Float
  isUpgrade     Boolean @default(false)
  baseProductId String?
  upgradeAdder  Float?
  location      String?
  sortOrder     Int     @default(0)
  product       Product @relation(fields: [productId], references: [id])
  quote         Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model Order {
  id                  String          @id @default(cuid())
  builderId           String
  quoteId             String?         @unique
  orderNumber         String          @unique
  poNumber            String?
  subtotal            Float
  taxAmount           Float           @default(0)
  shippingCost        Float           @default(0)
  total               Float
  paymentTerm         PaymentTerm
  paymentStatus       PaymentStatus   @default(PENDING)
  paidAt              DateTime?
  dueDate             DateTime?
  status              OrderStatus     @default(RECEIVED)
  deliveryDate        DateTime?
  deliveryNotes       String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  driverId            String?
  deliveryConfirmedAt DateTime?       @db.Timestamp(6)
  deliverySignature   String?
  inflowOrderId       String?         @unique
  trackingUpdates     Json?           @default("[]")
  qbTxnId             String?
  qbSyncedAt          DateTime?
  inflowCustomerId    String?
  jobs                Job[]
  builder             Builder         @relation(fields: [builderId], references: [id])
  quote               Quote?          @relation(fields: [quoteId], references: [id])
  items               OrderItem[]
  OrderTemplate       OrderTemplate[]

  @@index([builderId])
  @@index([orderNumber])
  @@index([status])
  @@index([builderId, status])
  @@index([createdAt])
  @@index([deliveryDate])
  @@index([paymentStatus])
  @@index([builderId, status], map: "idx_order_builder_status")
  @@index([status, createdAt(sort: Desc)], map: "idx_order_status_created")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  description String
  quantity    Int
  unitPrice   Float
  lineTotal   Float
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model OrderTemplate {
  id            String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  builderId     String
  name          String
  description   String?
  sourceOrderId String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @default(now()) @updatedAt
  builder       Builder             @relation(fields: [builderId], references: [id], onDelete: Cascade)
  Order         Order?              @relation(fields: [sourceOrderId], references: [id])
  items         OrderTemplateItem[]

  @@index([builderId], map: "idx_template_builder")
}

model OrderTemplateItem {
  id         String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  templateId String
  productId  String
  quantity   Int           @default(1)
  notes      String?
  product    Product       @relation(fields: [productId], references: [id])
  template   OrderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId], map: "idx_templateitem_template")
}

model Product {
  id              String              @id @default(cuid())
  sku             String              @unique
  name            String
  description     String?
  category        String
  subcategory     String?
  cost            Float
  basePrice       Float
  minMargin       Float               @default(0.25)
  doorSize        String?
  handing         String?
  coreType        String?
  panelStyle      String?
  jambSize        String?
  casingCode      String?
  hardwareFinish  String?
  material        String?
  fireRating      String?
  active          Boolean             @default(true)
  inStock         Boolean             @default(true)
  leadTimeDays    Int?
  inflowId        String?
  inflowCategory  String?
  lastSyncedAt    DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  imageAlt        String?
  imageUrl        String?
  thumbnailUrl    String?
  displayName     String?
  laborCost       Float?              @default(0)
  overheadCost    Float?              @default(0)
  locationId      String?             @default("loc_abel_dfw")
  categoryId      String?             @default("cat_doors")
  supplierId      String?
  supplierSku     String?
  weight          Float?
  dimensions      Json?               @default("{}")
  minOrderQty     Int?                @default(1)
  bomComponent    BomEntry[]          @relation("BomComponent")
  bomParent       BomEntry[]          @relation("BomParent")
  builderPrices   BuilderPricing[]
  DoorIdentity    DoorIdentity[]
  orderItems      OrderItem[]
  templateItems   OrderTemplateItem[]
  quoteItems      QuoteItem[]
  SupplierProduct SupplierProduct[]
  takeoffItems    TakeoffItem[]
  upgradeFrom     UpgradePath[]       @relation("UpgradeFrom")
  upgradeTo       UpgradePath[]       @relation("UpgradeTo")

  @@index([sku])
  @@index([category])
  @@index([active])
  @@index([lastSyncedAt])
  @@index([active, name], map: "idx_product_active_name")
  @@index([category, active], map: "idx_product_category_active")
  @@index([categoryId], map: "idx_product_category_id")
}

model BomEntry {
  id            String   @id @default(cuid())
  parentId      String
  componentId   String
  quantity      Float    @default(1)
  componentType String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  component     Product  @relation("BomComponent", fields: [componentId], references: [id], onDelete: Cascade)
  parent        Product  @relation("BomParent", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([parentId, componentId])
  @@index([parentId])
}

model BuilderPricing {
  id          String   @id @default(cuid())
  builderId   String
  productId   String
  customPrice Float
  margin      Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  builder     Builder  @relation(fields: [builderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([builderId, productId])
  @@index([builderId])
}

model UpgradePath {
  id            String   @id @default(cuid())
  fromProductId String
  toProductId   String
  upgradeType   String
  costDelta     Float
  priceDelta    Float
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  fromProduct   Product  @relation("UpgradeFrom", fields: [fromProductId], references: [id], onDelete: Cascade)
  toProduct     Product  @relation("UpgradeTo", fields: [toProductId], references: [id], onDelete: Cascade)

  @@unique([fromProductId, toProductId])
}

model HomeownerAccess {
  id          String               @id @default(cuid())
  builderId   String
  projectId   String
  name        String
  email       String
  phone       String?
  accessToken String               @unique
  active      Boolean              @default(true)
  expiresAt   DateTime?
  lastVisitAt DateTime?
  createdAt   DateTime             @default(now())
  builder     Builder              @relation(fields: [builderId], references: [id], onDelete: Cascade)
  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  selections  HomeownerSelection[]

  @@index([accessToken])
  @@index([projectId])
}

model HomeownerSelection {
  id                String          @id @default(cuid())
  homeownerAccessId String
  location          String
  baseProductId     String
  selectedProductId String
  adderCost         Float
  status            SelectionStatus @default(PENDING)
  confirmedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  homeownerAccess   HomeownerAccess @relation(fields: [homeownerAccessId], references: [id], onDelete: Cascade)
}

model Staff {
  id                                                       String                    @id @default(cuid())
  firstName                                                String
  lastName                                                 String
  email                                                    String                    @unique
  passwordHash                                             String
  phone                                                    String?
  role                                                     StaffRole
  department                                               Department
  title                                                    String?
  avatar                                                   String?
  active                                                   Boolean                   @default(true)
  hireDate                                                 DateTime?
  hourlyRate                                               Float?
  createdAt                                                DateTime                  @default(now())
  updatedAt                                                DateTime                  @updatedAt
  resetToken                                               String?
  resetTokenExpiry                                         DateTime?
  inviteToken                                              String?                   @unique @db.VarChar(255)
  inviteTokenExpiry                                        DateTime?                 @db.Timestamp(6)
  handbookSignedAt                                         DateTime?                 @db.Timestamp(6)
  handbookVersion                                          String?                   @db.VarChar(50)
  passwordSetAt                                            DateTime?                 @db.Timestamp(6)
  mustChangePassword                                       Boolean?                  @default(false)
  portalOverrides                                          Json?                     @default("{}")
  locationId                                               String?                   @default("loc_abel_dfw")
  roles                                                    String?
  activities                                               Activity[]
  AgentConversation                                        AgentConversation[]
  contractsCreated                                         Contract[]                @relation("ContractCreator")
  conversationsCreated                                     Conversation[]            @relation("ConversationCreator")
  conversations                                            ConversationParticipant[] @relation("ConversationParticipants")
  crewMembership                                           CrewMember[]
  ownedDeals                                               Deal[]                    @relation("DealOwner")
  dealActivities                                           DealActivity[]            @relation("DealActivities")
  decisionNotes                                            DecisionNote[]
  documentRequests                                         DocumentRequest[]         @relation("DocRequester")
  FloorPlan                                                FloorPlan[]
  Inspection                                               Inspection[]
  invoicesCreated                                          Invoice[]
  assignedJobs                                             Job[]                     @relation("AssignedPM")
  Location_Location_managerIdToStaff                       Location[]                @relation("Location_managerIdToStaff")
  messagesSent                                             Message[]                 @relation("MessagesSent")
  MessageReadReceipt                                       MessageReadReceipt[]
  notifications                                            Notification[]            @relation("StaffNotifications")
  poApprovals                                              PurchaseOrder[]           @relation("POApprover")
  purchaseOrders                                           PurchaseOrder[]           @relation("POCreator")
  qualityChecks                                            QualityCheck[]
  ScheduleChangeRequest                                    ScheduleChangeRequest[]
  Location_Staff_locationIdToLocation                      Location?                 @relation("Staff_locationIdToLocation", fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  StaffPreferences                                         StaffPreferences?
  StaffRoles                                               StaffRoles[]
  TakeoffInquiry                                           TakeoffInquiry[]
  tasks                                                    Task[]                    @relation("TaskAssignee")
  tasksCreated                                             Task[]                    @relation("TaskCreator")
  Trade                                                    Trade[]
  TradeReview                                              TradeReview[]
  WorkloadDelegation_WorkloadDelegation_createdByIdToStaff WorkloadDelegation[]      @relation("WorkloadDelegation_createdByIdToStaff")
  WorkloadDelegation_WorkloadDelegation_delegateIdToStaff  WorkloadDelegation[]      @relation("WorkloadDelegation_delegateIdToStaff")
  WorkloadDelegation_WorkloadDelegation_delegatorIdToStaff WorkloadDelegation[]      @relation("WorkloadDelegation_delegatorIdToStaff")

  @@index([email])
  @@index([role])
  @@index([department])
  @@index([active])
  @@index([createdAt])
  @@index([inviteToken])
  @@index([roles])
}

model Job {
  id                    String                  @id @default(cuid())
  jobNumber             String                  @unique
  boltJobId             String?
  inflowJobId           String?
  bwpPoNumber           String?
  orderId               String?
  projectId             String?
  lotBlock              String?
  community             String?
  builderName           String
  builderContact        String?
  jobAddress            String?
  scopeType             ScopeType
  dropPlan              String?
  assignedPMId          String?
  status                JobStatus               @default(CREATED)
  readinessCheck        Boolean                 @default(false)
  materialsLocked       Boolean                 @default(false)
  loadConfirmed         Boolean                 @default(false)
  scheduledDate         DateTime?
  actualDate            DateTime?
  completedAt           DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  communityId           String?
  hyphenJobId           String?
  hyphenScheduleId      String?
  divisionId            String?
  qcRequired            Boolean?                @default(true)
  allMaterialsAllocated Boolean?                @default(false)
  pickListGenerated     Boolean?                @default(false)
  buildSheetNotes       String?
  locationId            String?                 @default("loc_abel_dfw")
  activities            Activity[]
  btProjectMappings     BTProjectMapping[]
  BuilderScheduleShare  BuilderScheduleShare[]
  decisionNotes         DecisionNote[]
  deliveries            Delivery[]
  Inspection            Inspection[]
  installations         Installation[]
  assignedPM            Staff?                  @relation("AssignedPM", fields: [assignedPMId], references: [id])
  Community             Community?              @relation(fields: [communityId], references: [id])
  Division              Division?               @relation(fields: [divisionId], references: [id])
  order                 Order?                  @relation(fields: [orderId], references: [id])
  LienRelease           LienRelease[]
  materialPicks         MaterialPick[]
  qualityChecks         QualityCheck[]
  ScheduleChangeRequest ScheduleChangeRequest[]
  scheduleEntries       ScheduleEntry[]
  ScheduleMilestone     ScheduleMilestone[]
  tasks                 Task[]
  TradeReview           TradeReview[]

  @@index([status])
  @@index([assignedPMId])
  @@index([scheduledDate])
  @@index([builderName])
  @@index([community])
  @@index([divisionId])
  @@index([orderId])
  @@index([projectId])
  @@index([builderName, community], map: "idx_job_builder_community")
  @@index([assignedPMId, status], map: "idx_job_pm_status")
  @@index([status, scheduledDate], map: "idx_job_status_scheduled")
}

model DecisionNote {
  id            String           @id @default(cuid())
  jobId         String
  authorId      String
  noteType      DecisionNoteType
  subject       String
  body          String
  priority      NotePriority     @default(NORMAL)
  attachmentUrl String?
  relatedTaskId String?
  createdAt     DateTime         @default(now())
  author        Staff            @relation(fields: [authorId], references: [id])
  job           Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([noteType])
  @@index([authorId])
  @@index([createdAt])
  @@index([priority])
  @@index([jobId, createdAt(sort: Desc)], map: "idx_decisionnote_job_created")
}

model Activity {
  id           String       @id @default(cuid())
  staffId      String
  builderId    String?
  jobId        String?
  activityType ActivityType
  subject      String
  notes        String?
  outcome      String?
  scheduledAt  DateTime?
  completedAt  DateTime?
  durationMins Int?
  createdAt    DateTime     @default(now())
  job          Job?         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  staff        Staff        @relation(fields: [staffId], references: [id])

  @@index([builderId])
  @@index([jobId])
  @@index([staffId])
  @@index([activityType])
  @@index([createdAt])
  @@index([builderId, createdAt(sort: Desc)], map: "idx_activity_builder_created")
  @@index([jobId, createdAt(sort: Desc)], map: "idx_activity_job_created")
}

model Task {
  id          String       @id @default(cuid())
  assigneeId  String
  creatorId   String
  jobId       String?
  builderId   String?
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  category    TaskCategory @default(GENERAL)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  dealId      String?
  createdById String?
  assignee    Staff        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator     Staff        @relation("TaskCreator", fields: [creatorId], references: [id])
  job         Job?         @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([assigneeId])
  @@index([jobId])
  @@index([status])
  @@index([dueDate])
  @@index([category])
  @@index([createdAt])
  @@index([creatorId])
  @@index([assigneeId, status], map: "idx_task_assignee")
  @@index([assigneeId, status], map: "idx_task_assignee_status")
  @@index([dealId], map: "idx_task_deal")
  @@index([jobId, status], map: "idx_task_job_status")
  @@index([status, dueDate], map: "idx_task_status")
  @@index([status, dueDate], map: "idx_task_status_due")
}

model ScheduleEntry {
  id                    String                  @id @default(cuid())
  jobId                 String
  entryType             ScheduleType
  title                 String
  scheduledDate         DateTime
  scheduledTime         String?
  crewId                String?
  status                ScheduleStatus          @default(TENTATIVE)
  notes                 String?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  ScheduleChangeRequest ScheduleChangeRequest[]
  crew                  Crew?                   @relation(fields: [crewId], references: [id])
  job                   Job                     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([scheduledDate])
  @@index([crewId])
  @@index([status])
  @@index([entryType])
  @@index([jobId])
  @@index([crewId, scheduledDate], map: "idx_schedule_crew_date")
  @@index([scheduledDate, status], map: "idx_schedule_date_status")
}

model Crew {
  id                   String                 @id @default(cuid())
  name                 String
  crewType             CrewType
  active               Boolean                @default(true)
  vehicleId            String?
  vehiclePlate         String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  isSubcontractor      Boolean                @default(false)
  companyName          String?
  contactPhone         String?
  contactEmail         String?
  members              CrewMember[]
  deliveries           Delivery[]
  installations        Installation[]
  scheduleEntries      ScheduleEntry[]
  SubcontractorPricing SubcontractorPricing[]
}

model CrewMember {
  id        String    @id @default(cuid())
  crewId    String
  staffId   String
  role      String    @default("Member")
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt
  crew      Crew      @relation(fields: [crewId], references: [id], onDelete: Cascade)
  staff     Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([crewId, staffId])
}

model Delivery {
  id                    String                  @id @default(cuid())
  jobId                 String
  crewId                String?
  deliveryNumber        String                  @unique
  routeOrder            Int                     @default(0)
  address               String
  status                DeliveryStatus          @default(SCHEDULED)
  departedAt            DateTime?
