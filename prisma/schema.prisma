  @@index([type])
}

model OutreachStep {
  id           String           @id @default(cuid())
  sequenceId   String
  sequence     OutreachSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepNumber   Int
  delayDays    Int
  channel      String // EMAIL | CALL_TASK | SMS
  subject      String?
  bodyTemplate String
  createdAt    DateTime         @default(now())

  enrollmentSteps OutreachEnrollmentStep[]

  @@index([sequenceId])
}

model OutreachEnrollment {
  id          String           @id @default(cuid())
  sequenceId  String
  sequence    OutreachSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  prospectId  String?
  email       String
  companyName String
  contactName String
  currentStep Int              @default(0)
  status      String           @default("ACTIVE") // ACTIVE | PAUSED | COMPLETED | REPLIED | CONVERTED
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  updatedAt   DateTime         @updatedAt

  steps OutreachEnrollmentStep[]

  @@index([sequenceId])
  @@index([status])
  @@index([email])
}

model OutreachEnrollmentStep {
  id            String             @id @default(cuid())
  enrollmentId  String
  enrollment    OutreachEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  stepId        String
  step          OutreachStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)
  status        String             @default("PENDING") // PENDING | AWAITING_REVIEW | SENT | SKIPPED
  scheduledAt   DateTime
  sentAt        DateTime?
  openedAt      DateTime?
  repliedAt     DateTime?
  editedSubject String?
  editedBody    String?
  createdAt     DateTime           @default(now())

  @@index([enrollmentId])
  @@index([status])
  @@index([scheduledAt])
}

model OutreachTemplate {
  id           String   @id @default(cuid())
  templateType String
  name         String
  subject      String
  body         String
  category     String?
  createdAt    DateTime @default(now())

  @@index([templateType])
}

// ─── Financial Command Center ───────────────────────────────────────────

model FinancialSnapshot {
  id           String   @id @default(cuid())
  snapshotDate DateTime @default(now())

  // Cash position
  cashOnHand      Float @default(0)
  arTotal         Float @default(0)
  apTotal         Float @default(0)
  netCashPosition Float @default(0)

  // AR aging buckets
  arCurrent Float @default(0)
  ar30      Float @default(0)
  ar60      Float @default(0)
  ar90Plus  Float @default(0)

  // Key metrics
  dso          Float @default(0) // Days Sales Outstanding
  dpo          Float @default(0) // Days Payable Outstanding
  currentRatio Float @default(0)

  // Revenue
  revenueMonth Float @default(0)
  revenuePrior Float @default(0)
  revenueYTD   Float @default(0)

  // Commitments
  openPOTotal     Float @default(0)
  pendingInvoices Float @default(0)

  // Risk indicators
  overdueARPct Float @default(0) // % of AR that's overdue
  topExposure  Json? // Top 5 builder exposures

  createdAt DateTime @default(now())

  @@unique([snapshotDate])
  @@index([snapshotDate(sort: Desc)])
