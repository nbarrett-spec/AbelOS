// ─── ENUMS FOR MESSAGING & NOTIFICATIONS ────────────────────────

enum ConversationType {
  DIRECT
  GROUP
  CHANNEL
  DEPARTMENT
  BUILDER_SUPPORT // Builder-to-staff conversations
}

enum NotificationType {
  JOB_UPDATE
  TASK_ASSIGNED
  MESSAGE
  PO_APPROVAL
  DELIVERY_UPDATE
  QC_ALERT
  INVOICE_OVERDUE
  SCHEDULE_CHANGE
