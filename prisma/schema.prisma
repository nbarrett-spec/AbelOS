// ─── HYPHEN DOCUMENT PIPELINE ────────────────────────────────────────
// Incoming artifacts scraped from the Hyphen builder portal by the NUC
// scraper. Covers five distinct event shapes (plans, redlines, COs,
// schedule detail, closing dates) unified under one table. Correlation
// to a Job row happens at ingest time; unmatched rows surface in the
// admin review UI.
model HyphenDocument {
  id        String  @id @default(cuid())
  sourceId  String  @unique // idempotency key from NUC: "hyphen_<event_type>_<hash>"
  eventType String // "job_schedule_detail" | "red_line" | "plan_document" | "change_order_detail" | "closing_date"
  jobId     String? // resolved via correlation; NULL if unmatched
  builderId String? // resolved from builder_name match

  // Source metadata (from Hyphen)
  poNumber     String?
  builderName  String?
  subdivision  String?
  lotBlock     String?
  planElvSwing String?
  jobAddress   String?
  groupName    String? // Group 1 / Group 2
  phase        String?
  docCategory  String? // "Plans" | "Red Lines" | "Change Orders" | "Schedules"

  // PDF/file events
  fileName      String?
  fileUrl       String? // Vercel Blob URL or NUC-hosted fallback
  fileSha256    String?
  fileSizeBytes Int?
  contentType   String?

  // Schedule events
  closingDate       DateTime?
  requestedStart    DateTime?
  requestedEnd      DateTime?
  acknowledgedStart DateTime?
  acknowledgedEnd   DateTime?
  actualStart       DateTime?
  actualEnd         DateTime?
  permitNumber      String?
  isLate            Boolean?

  // Change orders
  coNumber         String?
  originalPo       String?
  coReason         String?
  coNetValueChange Decimal? @db.Decimal(12, 2)
  coBuilderStatus  String?

  // Match confidence
  matchConfidence String? // "HIGH" | "MEDIUM" | "LOW" | "UNMATCHED"
  matchMethod     String? // "po_exact" | "address_lot_builder" | "address_builder" | "unmatched"

  // Raw payload for audit
  rawPayload Json?

  scrapedAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job     Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  builder Builder? @relation(fields: [builderId], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([builderId])
  @@index([poNumber])
  @@index([eventType])
  @@index([docCategory])
  @@index([fileSha256])
  @@index([matchConfidence])
  @@index([scrapedAt(sort: Desc)])
}

// ──────────────────────────────────────────────────────────────────────────
// BUILDER ENRICHMENT + PITCH GENERATOR (added 2026-04-30)
// Lives on feat/builder-enrichment. Sales agents: enrich-prospect +
// generate-pitch. See src/lib/agents/ for the runtime, prisma/migrations/
// add_builder_enrichment_pitch.sql for the migration.
// ──────────────────────────────────────────────────────────────────────────

// Per-prospect pitch inputs that aren't part of the enrichment surface.
// 1:1 with Prospect (one PitchContext per prospect). Filled by Dalton via
// /admin/pitch-generator before generating a pitch, OR auto-pulled if the
// CRM gets these fields populated upstream.
model PitchContext {
  id         String   @id @default(cuid())
  prospectId String   @unique
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  // Sales positioning inputs
  targetPlans      Json? // [{ planName, sqFt, materialBudget, priorityRank }]
  currentVendor    String? // who Abel is replacing ("84 Lumber", "DW Distribution", etc.)
  estBuildVolume   Int? // homes per year (best estimate)
  dealStage        String? @default("COLD") // COLD | INTRO_SENT | IN_DISCUSSION | PROPOSAL | WON | LOST
  positioningNotes String? // free-form sales notes; fed to the pitch agent verbatim

  // Last-known relationship signals
  lastTouchedAt DateTime? @db.Timestamptz(6)
  lastTouchedBy String? // staffId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([prospectId])
  @@index([dealStage])
}

// Each generation request — input config + output URLs + status.
// Created when Dalton hits "Generate" on /admin/pitch-generator, OR when
// an auto-trigger fires (Phase 2: enrichment hits CONFIRMED → draft pitch).
model PitchRun {
  id         String   @id @default(cuid())
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  // Style/layout/elements — config the user picked
  style    String // HERITAGE | EXECUTIVE | BUILDER_FIELD
  layout   String // MICROSITE | DECK | ONE_PAGER
  elements String[] // ['cover','exec_summary','pricing','plan_breakdown','value_eng','scope','capabilities','team','financials','references','timeline','terms']

  // Run state
  status       String   @default("QUEUED") // QUEUED | GENERATING | PREVIEW | APPROVED | SENT | FAILED
  previewUrl   String? // Vercel preview deploy URL (microsite)
  htmlContent  String? // Generated HTML (for microsite layout)
  pptxFileId   String? // Files API ref (for deck layout — Phase 2)
  pdfFileId    String? // Files API ref (for one-pager layout — Phase 2)
  emailDraft   String? // Markdown draft email body (queued in ReviewQueue for approval)
  errorMessage String?
  costEstimate Decimal? @db.Decimal(8, 4) // USD; tallies Anthropic input/output + image gen + Vercel

  // Provenance
  generatedBy String? // staffId; null if auto-triggered
  approvedBy  String? // staffId; set when ReviewQueue approves
  approvedAt  DateTime? @db.Timestamptz(6)
  sentAt      DateTime? @db.Timestamptz(6)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([prospectId])
  @@index([status])
  @@index([createdAt(sort: Desc)], map: "idx_pitchrun_created")
  @@index([generatedBy])
}

// Single review queue across enrichment, pitch approvals, and outbound emails.
// CLAUDE.md hard rule: external customer emails need DFW outreach approval.
// This is the gate. Items land here when:
//   - Enrichment confidence = UNVERIFIED + source URLs conflict
//   - Pitch generator finishes (status: PREVIEW) and needs Nate's approval
//   - Resend bounce flags a prospect for re-research
model ReviewQueue {
  id String @id @default(cuid())

  // What needs review
  entityType String // PROSPECT_ENRICHMENT | PITCH_RUN | EMAIL_SEND | BOUNCE_RECHECK
  entityId   String // FK by convention to Prospect.id, PitchRun.id, etc.

  // Why it landed here + what to do
  reason          String // short label for UI: "low_confidence_email", "pitch_ready_review", etc.
  summary         String? // one-liner the reviewer sees in the queue list
  suggestedAction Json? // { type: "approve_send", payload: {...} } — agent's recommendation

  // Resolution
  status     String    @default("PENDING") // PENDING | APPROVED | REJECTED | EXPIRED
  reviewedBy String? // staffId
  reviewedAt DateTime? @db.Timestamptz(6)
  notes      String? // reviewer notes (free-form)

  createdAt DateTime  @default(now())
  expiresAt DateTime? @db.Timestamptz(6) // optional auto-expire (e.g., stale pitch previews)

  @@index([status, createdAt(sort: Desc)], map: "idx_reviewq_pending")
  @@index([entityType, entityId], map: "idx_reviewq_entity")
  @@index([reviewedBy])
}

