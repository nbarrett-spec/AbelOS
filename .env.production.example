# ═══════════════════════════════════════════════════════════════════════
# Abel Builder Platform — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env.production and fill in ALL values before deploying.
# NEVER commit the actual .env.production file to git.

# Database (PostgreSQL / Neon Serverless — use POOLED connection URL)
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

# Auth — REQUIRED. Generate with: openssl rand -base64 48
# DO NOT use the example below — generate your own unique secret:
JWT_SECRET="<GENERATE-WITH: openssl rand -base64 48>"

# Email (Resend) — required for order confirmations, password resets
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Abel Lumber <noreply@abellumber.com>"

# App — update with your production domain
NEXT_PUBLIC_APP_URL="https://builders.abellumber.com"
NEXT_PUBLIC_APP_NAME="Abel Builder Platform"

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=50

# Document Center — absolute path to company documents on the server
# Leave commented out if not deploying document center
# DOCUMENTS_PATH="/opt/abel/documents"

# Node environment — MUST be "production"
NODE_ENV="production"
