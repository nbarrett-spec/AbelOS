{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && next build",
  "installCommand": "npm install",
  "regions": [
    "iad1"
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/uploads/:path*",
      "destination": "/api/files/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/quote-followups",
      "schedule": "0 9 * * 1-5"
    },
    {
      "path": "/api/cron/quote-expiration",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/agent-opportunities",
      "schedule": "0 14 * * 1-5"
    },
    {
      "path": "/api/cron/inflow-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/hyphen-sync",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/buildertrend-sync",
      "schedule": "15 */2 * * *"
    },
    {
      "path": "/api/cron/run-automations",
      "schedule": "0 8,13,17 * * 1-5"
    },
    {
      "path": "/api/cron/mrp-nightly",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/webhook-retry",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/zombie-sweep",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/uptime-probe",
      "schedule": "*/5 * * * *"
    },
    {
