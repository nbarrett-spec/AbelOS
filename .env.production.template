# ============================================================
# Abel Lumber Builder Platform — Production Environment
# ============================================================
# Copy this file to .env.production.local and fill in all values.
# NEVER commit the filled-in version to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Neon PostgreSQL connection string. Use the POOLED connection.
# Rotate password immediately if the dev .env was ever committed.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ── Authentication ───────────────────────────────────────────
# CRITICAL: Must be unique, random, 48+ chars. NEVER commit the real value.
# Generate with: openssl rand -base64 48
# The previously-committed value in this file (git history) was leaked via
# public GitHub on 2026-04-24 and ROTATED the same day. If you're setting up
# a fresh env, generate a NEW secret — do not reuse any value from git history.
JWT_SECRET="<GENERATE_WITH_openssl_rand_base64_48_DO_NOT_COMMIT_REAL_VALUE>"

# ── Application URL ──────────────────────────────────────────
# The public-facing URL of your app (no trailing slash).
# Used in emails, password reset links, homeowner portal links.
NEXT_PUBLIC_APP_URL="https://app.abellumber.com"
NEXT_PUBLIC_APP_NAME="Abel Lumber"

# ── Email (Resend) ───────────────────────────────────────────
# Sign up at https://resend.com, verify your domain, get API key.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Abel Lumber <noreply@abellumber.com>"

# ── File Storage ─────────────────────────────────────────────
# For Vercel: Use Vercel Blob (vercel.com/storage/blob)
# For self-hosted: Set to an S3-compatible path or local mount
# IMPORTANT: Local filesystem (./uploads) is EPHEMERAL on Vercel!
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=50

# ── Node Environment ─────────────────────────────────────────
NODE_ENV=production
