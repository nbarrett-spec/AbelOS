# ═══════════════════════════════════════════════════════════════════════
# Abel Builder Platform — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy to .env and fill in values. NEVER commit .env to git.

# Database (PostgreSQL / Neon Serverless — use POOLED connection)
DATABASE_URL="postgresql://user:password@localhost:5432/abel_builder?sslmode=require"

# Auth — REQUIRED. Generate with: openssl rand -base64 48
JWT_SECRET="<GENERATE: openssl rand -base64 48>"

# Email (Resend — https://resend.com)
# Required for: order confirmations, password resets, quote follow-ups, homeowner invites
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Abel Lumber <noreply@abellumber.com>"

# Payments (Stripe — https://dashboard.stripe.com/apikeys)
# Required for: online payments, invoice collection
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Cron Jobs — secret for authenticating Vercel cron requests
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# Claude AI Assistant (Anthropic)
ANTHROPIC_API_KEY=""

# Agent Hub — API key for NUC agent cluster (server-to-server auth)
AGENT_HUB_API_KEY=""

# QuickBooks Web Connector
QBWC_USERNAME=""
QBWC_PASSWORD=""

# Error Monitoring (Sentry — https://sentry.io)
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Upstash Redis (rate limiting) — https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=50

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Abel Builder Platform"
NEXT_PUBLIC_SENTRY_DSN=""

# Node environment — set to "production" for deployment
NODE_ENV="development"
