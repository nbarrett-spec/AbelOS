# ═══════════════════════════════════════════════════════════════════════════
# Abel Builder Platform — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in YOUR values.
# NEVER commit .env to git — it contains secrets.
#
# For onboarding:
#   1. Copy this file: `cp .env.example .env`
#   2. Fill in required variables (DATABASE_URL, JWT_SECRET)
#   3. Run migrations: `npm run db:push`
#   4. Start dev: `npm run dev`
#
# For production deployment:
#   - All required variables MUST be set
#   - Use strong secrets (openssl rand -base64 48)
#   - Use connection poolers for DATABASE_URL
#   - Enable Sentry for error tracking
#   - Set STRIPE_* and RESEND_* for payments and email
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# Core & Runtime
# ───────────────────────────────────────────────────────────────────────────

# Node environment: development | production | test
NODE_ENV="development"

# ───────────────────────────────────────────────────────────────────────────
# Database (REQUIRED)
# ───────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string. For production, use a pooler:
# - Neon: postgresql://[user]:[password]@[host]-pooler.c.[region].us-east-1.aws.neon.tech/[db]?sslmode=require
# - PgBouncer: postgresql://[user]:[password]@[pgbouncer-host]:6432/[db]?sslmode=require
# - Supabase (pooler): postgresql://[user].[password]@db.[host].supabase.co:6543/postgres?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/abel_builder?sslmode=disable"

# Direct PostgreSQL URL for migrations (only needed when using poolers).
# Set to non-pooled version for migrations to avoid connection exhaustion.
# Example (Neon direct): postgresql://[user]:[password]@[host].c.[region].us-east-1.aws.neon.tech/[db]?sslmode=require
DIRECT_URL=""

# ───────────────────────────────────────────────────────────────────────────
# Authentication & Security (REQUIRED)
# ───────────────────────────────────────────────────────────────────────────

# JWT secret for signing auth tokens. MUST be 32+ chars and unique per environment.
# Generate a strong secret:
#   macOS/Linux:  openssl rand -base64 48
#   Windows:      openssl rand -base64 48
# DO NOT use the same secret across environments (dev, staging, prod).
# DO NOT commit this value to git.
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars-minimum"

# Secret for authenticating Vercel cron jobs.
# Generate:  openssl rand -hex 32
CRON_SECRET=""

# ───────────────────────────────────────────────────────────────────────────
# Email (Optional but recommended for production)
# ───────────────────────────────────────────────────────────────────────────
# Uses Resend (https://resend.com) for transactional email.
# Required for: order confirmations, password resets, quote follow-ups, homeowner invites

# Resend API key (https://resend.com/keys)
RESEND_API_KEY=""

# From email address. Can include display name: "Abel Lumber <noreply@abellumber.com>"
RESEND_FROM_EMAIL="Abel Lumber <noreply@abellumber.com>"

# ───────────────────────────────────────────────────────────────────────────
# Payments (Optional but required for production)
# ───────────────────────────────────────────────────────────────────────────
# Uses Stripe (https://stripe.com) for online payments and invoicing.

# Stripe secret key (starts with sk_live_ in production, sk_test_ in development)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""

# Stripe webhook signing secret
# Get from: https://dashboard.stripe.com/webhooks
# Used to verify webhook authenticity from Stripe
STRIPE_WEBHOOK_SECRET=""

# ───────────────────────────────────────────────────────────────────────────
# AI & Agents
# ───────────────────────────────────────────────────────────────────────────

# Anthropic API key for Claude AI integration
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=""

# Agent Hub API key for NUC agent cluster (server-to-server authentication)
# Use for AI agents communicating with the platform backend
AGENT_HUB_API_KEY=""

# ───────────────────────────────────────────────────────────────────────────
# Integrations
# ───────────────────────────────────────────────────────────────────────────

# QuickBooks Web Connector credentials
# Used for syncing financial data with QuickBooks Desktop
QBWC_USERNAME=""
QBWC_PASSWORD=""

# ───────────────────────────────────────────────────────────────────────────
# Error Monitoring (Optional, recommended for production)
# ───────────────────────────────────────────────────────────────────────────
# Uses Sentry (https://sentry.io) for real-time error tracking and alerting.

# Sentry DSN for server-side error tracking
# Get from: https://sentry.io/settings/[org]/projects/[project]/keys/
SENTRY_DSN=""

# Sentry auth token for releases and source map uploads
# Get from: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=""

# Sentry DSN for client-side (browser) error tracking
# Use a separate DSN or the same one, depending on your Sentry configuration
NEXT_PUBLIC_SENTRY_DSN=""

# ───────────────────────────────────────────────────────────────────────────
# Rate Limiting (Optional, for production scale)
# ───────────────────────────────────────────────────────────────────────────
# Uses Upstash Redis (https://console.upstash.com) for distributed rate limiting.

# Upstash Redis REST endpoint
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=""

# Upstash Redis REST API token
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_TOKEN=""

# ───────────────────────────────────────────────────────────────────────────
# App Configuration
# ───────────────────────────────────────────────────────────────────────────

# Public-facing app URL (used for email links, OAuth redirects, etc.)
# Development: http://localhost:3000
# Staging: https://staging-app.abellumber.com
# Production: https://app.abellumber.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Alternative internal base URL (if different from NEXT_PUBLIC_APP_URL)
NEXT_PUBLIC_BASE_URL=""

# App display name
NEXT_PUBLIC_APP_NAME="Abel Builder Platform"

# ───────────────────────────────────────────────────────────────────────────
# File Uploads
# ───────────────────────────────────────────────────────────────────────────

# Directory for uploaded files (quotes, PDFs, images, etc.)
UPLOAD_DIR="./uploads"

# Maximum file upload size in MB
MAX_FILE_SIZE_MB=50

# Document storage path (if different from UPLOAD_DIR)
DOCUMENTS_PATH=""

# App URL (may differ from NEXT_PUBLIC_APP_URL if using a reverse proxy)
APP_URL=""

# ═══════════════════════════════════════════════════════════════════════════
# Summary
# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED (must be set):
#   - DATABASE_URL
#   - JWT_SECRET
#   - NODE_ENV (defaults to development)
#
# RECOMMENDED for production:
#   - DIRECT_URL (for migrations on poolers)
#   - CRON_SECRET
#   - STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
#   - RESEND_API_KEY, RESEND_FROM_EMAIL
#   - SENTRY_DSN, NEXT_PUBLIC_SENTRY_DSN
#   - UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN
#
# OPTIONAL:
#   - All others (AI, QuickBooks, Agent Hub keys)
#
# For more information, see docs/ENVIRONMENT.md or CLAUDE_CODE_HANDOFF.md
# ═══════════════════════════════════════════════════════════════════════════
