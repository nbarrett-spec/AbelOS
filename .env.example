# ═══════════════════════════════════════════════════════════════════════════
# Abel Builder Platform — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in YOUR values.
# NEVER commit .env to git — it contains secrets.
#
# For onboarding:
#   1. Copy this file: `cp .env.example .env`
#   2. Fill in required variables (DATABASE_URL, JWT_SECRET)
#   3. Run migrations: `npm run db:push`
#   4. Start dev: `npm run dev`
#
# For production deployment:
#   - All required variables MUST be set
#   - Use strong secrets (openssl rand -base64 48)
#   - Use connection poolers for DATABASE_URL
#   - Enable Sentry for error tracking
#   - Set STRIPE_* and RESEND_* for payments and email
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# Core & Runtime
# ───────────────────────────────────────────────────────────────────────────

# Node environment: development | production | test
NODE_ENV="development"

# ───────────────────────────────────────────────────────────────────────────
# Database (REQUIRED)
# ───────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string. For production, use a pooler:
# - Neon: postgresql://[user]:[password]@[host]-pooler.c.[region].us-east-1.aws.neon.tech/[db]?sslmode=require
# - PgBouncer: postgresql://[user]:[password]@[pgbouncer-host]:6432/[db]?sslmode=require
# - Supabase (pooler): postgresql://[user].[password]@db.[host].supabase.co:6543/postgres?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/abel_builder?sslmode=disable"

# Direct PostgreSQL URL for migrations (only needed when using poolers).
# Set to non-pooled version for migrations to avoid connection exhaustion.
# Example (Neon direct): postgresql://[user]:[password]@[host].c.[region].us-east-1.aws.neon.tech/[db]?sslmode=require
DIRECT_URL=""

# ───────────────────────────────────────────────────────────────────────────
# Authentication & Security (REQUIRED)
# ───────────────────────────────────────────────────────────────────────────

# JWT secret for signing auth tokens. MUST be 32+ chars and unique per environment.
# Generate a strong secret:
#   macOS/Linux:  openssl rand -base64 48
#   Windows:      openssl rand -base64 48
# DO NOT use the same secret across environments (dev, staging, prod).
# DO NOT commit this value to git.
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars-minimum"

# Secret for authenticating Vercel cron jobs.
# Generate:  openssl rand -hex 32
CRON_SECRET=""

# ───────────────────────────────────────────────────────────────────────────
# Email (Optional but recommended for production)
# ───────────────────────────────────────────────────────────────────────────
# Uses Resend (https://resend.com) for transactional email.
# Required for: order confirmations, password resets, quote follow-ups, homeowner invites

# Resend API key (https://resend.com/keys)
RESEND_API_KEY=""

# From email address. Can include display name: "Abel Lumber <noreply@abellumber.com>"
RESEND_FROM_EMAIL="Abel Lumber <noreply@abellumber.com>"

# ───────────────────────────────────────────────────────────────────────────
# Payments (Optional but required for production)
# ───────────────────────────────────────────────────────────────────────────
# Uses Stripe (https://stripe.com) for online payments and invoicing.

# Stripe secret key (starts with sk_live_ in production, sk_test_ in development)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""

# Stripe webhook signing secret
# Get from: https://dashboard.stripe.com/webhooks
# Used to verify webhook authenticity from Stripe
STRIPE_WEBHOOK_SECRET=""

# ───────────────────────────────────────────────────────────────────────────
# AI & Agents
# ───────────────────────────────────────────────────────────────────────────

# Anthropic API key for Claude AI integration
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=""

# Agent Hub API key for NUC agent cluster (server-to-server authentication)
# Use for AI agents communicating with the platform backend
AGENT_HUB_API_KEY=""

# NUC Brain Engine — service-to-service auth for Brain ↔ Aegis integration
# NUC_BRAIN_API_KEY: authenticates incoming pushes from Brain (scores, alerts, actions)
#   Set to the same value as AEGIS_API_KEY on the NUC .env
# NUC_BRAIN_URL: where the proxy route forwards frontend queries to the Brain API
# CF_ACCESS_CLIENT_ID / CF_ACCESS_CLIENT_SECRET: Cloudflare Access service token
#   for server-side calls through the tunnel (proxy route + Brain pull)
NUC_BRAIN_API_KEY=""
NUC_BRAIN_URL="https://brain.abellumber.com"
CF_ACCESS_CLIENT_ID=""
CF_ACCESS_CLIENT_SECRET=""

# ───────────────────────────────────────────────────────────────────────────
# Integrations
# ───────────────────────────────────────────────────────────────────────────

# ───────────────────────────────────────────────────────────────────────────
# QuickBooks Online (QBO) — OAuth2
# ───────────────────────────────────────────────────────────────────────────
# Decision 2026-04-22: KILLED the QuickBooks Desktop Web Connector (QBWC)
# path; went with QuickBooks Online OAuth2 instead. See
# memory/projects/quickbooks-decision.md.
#
# Phase 2 — not yet active. The scaffold is in place (status route, Connect
# page, stubbed syncInvoices/syncPayments/syncJournals). Setting these now
# prepares the env; Phase 2 flips the switch that turns on real syncs.
#
# Intuit app credentials: https://developer.intuit.com/app/developer/dashboard
QBO_CLIENT_ID=""
QBO_CLIENT_SECRET=""
# QuickBooks company (realm) ID — shown on the OAuth callback after connect
QBO_REALM_ID=""
# Refresh token we persist after the OAuth authorization-code exchange
QBO_REFRESH_TOKEN=""
# Short-lived access token (refreshed on demand; usually left unset in env)
QBO_ACCESS_TOKEN=""
# Defaults to https://quickbooks.api.intuit.com/v3 — override for sandbox
QBO_API_BASE=""

# InFlow Cloud inventory sync
# Used by scripts/pull-inflow-orders.ts, /api/ops/inflow/*, and the hourly
# inflow-sync cron to pull product catalog and sales orders into Aegis.
# Dashboard: https://app.inflowinventory.com → Settings → API
INFLOW_API_KEY=""
# InFlow company UUID (shown in the URL of the Cloud app after login)
INFLOW_COMPANY_ID=""

# ElevenLabs text-to-speech
# Drives voice alerts for driver dispatch (urgent delivery notices) and
# collections (past-due builder call scripts).
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=""

# ───────────────────────────────────────────────────────────────────────────
# Admin bootstrap (DANGEROUS — leave off in production)
# ───────────────────────────────────────────────────────────────────────────
# ADMIN_SEED_ENABLED gates /api/admin/seed, the one-shot endpoint that
# bootstraps the first OWNER account. Leave unset or "false" in production.
# Only flip to "true" temporarily when rotating the owner account or when
# standing up a fresh environment, then set it back to "false".
ADMIN_SEED_ENABLED="false"
# 32+ char random string required alongside ADMIN_SEED_ENABLED. Generate with:
#   openssl rand -hex 32
ADMIN_SEED_KEY=""

# ───────────────────────────────────────────────────────────────────────────
# Webhook Secrets (REQUIRED for production — verify inbound webhooks)
# ───────────────────────────────────────────────────────────────────────────
# Each integration needs its own webhook signing secret.
# Generate each with:  openssl rand -hex 32

EMAIL_WEBHOOK_SECRET=""
HYPHEN_WEBHOOK_SECRET=""
INFLOW_WEBHOOK_SECRET=""
INTERNAL_LOG_SECRET=""

# ───────────────────────────────────────────────────────────────────────────
# Google Workspace / Gmail Sync
# ───────────────────────────────────────────────────────────────────────────
# Service account with domain-wide delegation for multi-mailbox sync.
# Service account: gmail-sync@abel-os-gmail-sync.iam.gserviceaccount.com
#
# Option A: Paste the full JSON key contents (Vercel recommended):
GOOGLE_SERVICE_ACCOUNT_KEY=""
#
# Option B: Path to JSON key file (NUC / Docker):
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH="/path/to/abel-os-gmail-sync-74444d054bc7.json"

# Legacy: used by webhook/Apps Script sync paths
GMAIL_PUBSUB_AUDIENCE=""
GMAIL_PUBSUB_SERVICE_ACCOUNT=""
GMAIL_SYNC_API_KEY=""
GMAIL_WEBHOOK_TOKEN=""
API_SECRET_KEY=""

# ───────────────────────────────────────────────────────────────────────────
# Error Monitoring (Optional, recommended for production)
# ───────────────────────────────────────────────────────────────────────────
# Uses Sentry (https://sentry.io) for real-time error tracking and alerting.

# Sentry DSN for server-side error tracking
# Get from: https://sentry.io/settings/[org]/projects/[project]/keys/
SENTRY_DSN=""

# Sentry auth token for releases and source map uploads
# Get from: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=""

# Sentry DSN for client-side (browser) error tracking
# Use a separate DSN or the same one, depending on your Sentry configuration
NEXT_PUBLIC_SENTRY_DSN=""

# ───────────────────────────────────────────────────────────────────────────
# Rate Limiting (Optional, for production scale)
# ───────────────────────────────────────────────────────────────────────────
# Uses Upstash Redis (https://console.upstash.com) for distributed rate limiting.

# Upstash Redis REST endpoint
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=""

# Upstash Redis REST API token
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_TOKEN=""

# ───────────────────────────────────────────────────────────────────────────
# Monitoring & Alerting
# ───────────────────────────────────────────────────────────────────────────

# Comma-separated list of email addresses for system alert notifications
ALERT_NOTIFY_EMAILS=""

# Performance thresholds (optional, sensible defaults in code)
# N_PLUS_ONE_THRESHOLD=5
# PRISMA_SLOW_QUERY_MS=200

# ───────────────────────────────────────────────────────────────────────────
# App Configuration
# ───────────────────────────────────────────────────────────────────────────

# Public-facing app URL (used for email links, OAuth redirects, etc.)
# Development: http://localhost:3000
# Staging: https://staging-app.abellumber.com
# Production: https://app.abellumber.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Alternative internal base URL (if different from NEXT_PUBLIC_APP_URL)
NEXT_PUBLIC_BASE_URL=""

# App display name
NEXT_PUBLIC_APP_NAME="Abel Builder Platform"

# Deployment tag shown in the status bar / about page so we can tell at a
# glance which build is running. Typically the Git SHA or a Vercel deploy ID;
# leave blank in dev.
NEXT_PUBLIC_DEPLOY_TAG=""

# ───────────────────────────────────────────────────────────────────────────
# File Uploads
# ───────────────────────────────────────────────────────────────────────────

# Directory for uploaded files (quotes, PDFs, images, etc.)
UPLOAD_DIR="./uploads"

# Maximum file upload size in MB
MAX_FILE_SIZE_MB=50

# Document storage path (if different from UPLOAD_DIR)
DOCUMENTS_PATH=""

# App URL (may differ from NEXT_PUBLIC_APP_URL if using a reverse proxy)
APP_URL=""

# ───────────────────────────────────────────────────────────────────────────
# Feature Flags (Aegis v2 rollout)
# ───────────────────────────────────────────────────────────────────────────
# Each NEXT_PUBLIC_ flag is inlined at build time and read by useFeatureFlag().
# Users can override per-browser via localStorage ("feature.{NAME}") or
# per-user via Staff.preferences.featureFlags.
#
# AEGIS_V2_DRAFTING_ROOM — gates the new "Drafting Room" visual system
# (density toggle, login blueprint animation, updated error pages,
#  3D yard twin, etc.). Leave blank or "0" to keep the legacy UI.
# Set to "1" in Preview/staging to dogfood before shipping to production.
NEXT_PUBLIC_AEGIS_V2_DRAFTING_ROOM=""

# ═══════════════════════════════════════════════════════════════════════════
# Summary
# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED (must be set for app to start):
#   - DATABASE_URL
#   - JWT_SECRET
#   - NODE_ENV (defaults to development)
#
# REQUIRED for production:
#   - DIRECT_URL (for migrations on poolers)
#   - CRON_SECRET (authenticates Vercel cron jobs)
#   - STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET (payments)
#   - RESEND_API_KEY, RESEND_FROM_EMAIL (transactional email)
#   - EMAIL_WEBHOOK_SECRET, HYPHEN_WEBHOOK_SECRET, INFLOW_WEBHOOK_SECRET (webhook verification)
#   - ANTHROPIC_API_KEY (AI takeoffs, agent hub, blueprint analysis)
#
# RECOMMENDED for production:
#   - SENTRY_DSN, NEXT_PUBLIC_SENTRY_DSN (error tracking)
#   - UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN (rate limiting)
#   - ALERT_NOTIFY_EMAILS (system alert notifications)
#
# OPTIONAL:
#   - QBO_CLIENT_ID, QBO_CLIENT_SECRET, QBO_REALM_ID (QuickBooks Online — phase 2 scaffold)
#   - GMAIL_* vars (communication log Gmail sync)
#   - AGENT_HUB_API_KEY (NUC agent cluster)
#   - NUC_BRAIN_API_KEY, NUC_BRAIN_URL (Brain engine integration)
#   - CF_ACCESS_CLIENT_ID, CF_ACCESS_CLIENT_SECRET (Cloudflare Access for NUC tunnel)
#
# REMOVED 2026-04-22:
#   - QBWC_USERNAME / QBWC_PASSWORD — QB Desktop Web Connector path killed
#     in favor of QBO OAuth2; see memory/projects/quickbooks-decision.md.
#   - CURRI_API_KEY / CURRI_API_URL — Curri evaluation deferred; in-house
#     drivers handle all deliveries. See memory/projects/delivery-partners.md.
#   - TWILIO_AUTH_TOKEN / TWILIO_WEBHOOK_SECRET — SMS agent placeholder
#     pulled; /api/agent/sms now returns 501. Re-add when we wire Twilio
#     for real.
# ═══════════════════════════════════════════════════════════════════════════
